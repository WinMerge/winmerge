<?xml version="1.0" encoding="UTF-8"?>
<appendix id="Shortcut_keys">
  <title>Tasti di scelta rapida<indexterm>
      <primary>tasti di scelta rapida</primary>
    </indexterm></title>

  <para>WinMerge include la maggior parte dei tasti di scelta rapida familiari
comunemente utilizzati in altre applicazioni Windows.</para>

  <table>
    <title>Generale</title>

    <tgroup cols="2">
      <thead>
        <row>
          <entry>Chiavi</entry>

          <entry>Funzione</entry>
        </row>
      </thead>

      <tbody>
        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Tab</keycap> </keycombo></entry>

          <entry>Passa alla scheda successiva</entry>

        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Maiusc</keycap>
<keycap>Tab</keycap> </keycombo></entry>

          <entry>Passa alla scheda precedente</entry>

        </row>

      </tbody>
    </tgroup>
  </table>

  <table>
    <title>Confronto cartelle</title>

    <tgroup cols="2">
      <thead>
        <row>
          <entry>Chiavi</entry>

          <entry>Funzione</entry>
        </row>
      </thead>

      <tbody>
        <row>
          <entry><keycap>Invio</keycap></entry>

          <entry>Apri il file o la cartella selezionati</entry>
        </row>

        <row>
          <entry><keycap>Backspace</keycap></entry>

          <entry>Apri la cartella principale se possibile (disponibile solo quando le
sottocartelle non sono incluse nel confronto)</entry>
        </row>

        <row>
          <entry><keycap>F5</keycap></entry>

          <entry>Nuova scansione delle cartelle</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Home</keycap> </keycombo></entry>

          <entry>Vai al primo file o cartella diverso</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Fine</keycap> </keycombo></entry>

          <entry>Vai all'ultimo file o cartella diverso</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Invio</keycap> </keycombo></entry>

          <entry>Vai all'elemento attualmente selezionato (se fatto scorrere fuori dallo
schermo)</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Freccia su</keycap> </keycombo></entry>

          <entry>Vai al file o alla cartella precedente diversa</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Freccia giù</keycap> </keycombo></entry>

          <entry>Vai al file o alla cartella successiva</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Freccia sinistra</keycap>
</keycombo></entry>

          <entry>Copia gli elementi selezionati da destra a sinistra</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Freccia destra</keycap> </keycombo></entry>

          <entry>Copia gli elementi selezionati da sinistra a destra</entry>
        </row>
      </tbody>
    </tgroup>
  </table>

  <table>
    <title>Confronto file</title>

    <tgroup cols="2">
      <thead>
        <row>
          <entry>Chiavi</entry>

          <entry>Funzione</entry>
        </row>
      </thead>

      <tbody>
        <row>
          <entry><keycap>Esc</keycap></entry>

          <entry>Chiudi finestra (se abilitato nelle opzioni)</entry>
        </row>

        <row>
          <entry><keycap>F4</keycap></entry>

          <entry>Visualizza la differenza della riga successiva</entry>
        </row>

        <row>
          <entry><keycap>Maiusc</keycap>+<keycap>F4</keycap></entry>

          <entry>Visualizza la differenza della linea precedente</entry>
        </row>

        <row>
          <entry><keycap>F5</keycap></entry>

          <entry>Aggiorna</entry>
        </row>

        <row>
          <entry><keycap>Ctrl</keycap>+<keycap>F5</keycap></entry>

          <entry>Ricaricare</entry>
        </row>

        <row>
          <entry><keycap>F6</keycap></entry>

          <entry>Passa al riquadro successivo (file attivo)</entry>
        </row>

        <row>
          <entry><keycap>Maiusc</keycap>+<keycap>F6</keycap></entry>

          <entry>Passa al riquadro precedente (file attivo)</entry>
        </row>

        <row>
          <entry><keycap>F7</keycap></entry>

          <entry>Vai alla differenza precedente</entry>
        </row>

        <row>
          <entry><keycap>Maiusc</keycap>+<keycap>F7</keycap></entry>

          <entry>Vai al conflitto precedente</entry>
        </row>

        <row>
          <entry><keycap>Ctrl</keycap>+<keycap>F7</keycap></entry>

          <entry>Vai al file precedente</entry>
        </row>

        <row>
          <entry><keycap>F8</keycap></entry>

          <entry>Vai alla differenza successiva</entry>
        </row>

        <row>
          <entry><keycap>Maiusc</keycap>+<keycap>F8</keycap></entry>

          <entry>Vai al conflitto successivo</entry>
        </row>

        <row>
          <entry><keycap>Ctrl</keycap>+<keycap>F8</keycap></entry>

          <entry>Vai al file successivo</entry>
        </row>

        <row>
          <entry><keycap>F9</keycap></entry>

          <entry>Modalità di unione attivata o disattivata (attiva/disattiva)</entry>
        </row>

        <row>
          <entry><keycap>F12</keycap></entry>

          <entry>Vai alla definizione</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>B</keycap> </keycombo></entry>

          <entry>Inizia la selezione della colonna</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>D</keycap> </keycombo></entry>

          <entry>Attiva/disattiva la modalità contesto differenze</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Alt</keycap> <keycap>E</keycap>
</keycombo></entry>

          <entry>Apri con editor esterno</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>G</keycap> </keycombo></entry>

          <entry>Vai alla differenza o alla linea</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Maiusc</keycap> <keycap>G</keycap>
</keycombo></entry>

          <entry>Vai alla riga spostata (2 riquadri)</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Maiusc</keycap> <keycap>G</keycap>
</keycombo></entry>

          <entry>Vai alla linea spostata tra il lato sinistro e il centro (3 riquadri)</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Alt</keycap> <keycap>G</keycap>
</keycombo></entry>

          <entry>Vai alla linea spostata tra il lato centrale e quello destro (3 riquadri)</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Maiusc</keycap> <keycap>M</keycap>
</keycombo></entry>

          <entry>Aggiungi marcatore</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Alt</keycap> <keycap>M</keycap>
</keycombo></entry>

          <entry>L'auto è in funzione</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>S</keycap> </keycombo></entry>

          <entry>Aggiungi punto di sincronizzazione</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>U</keycap> </keycombo></entry>

          <entry>Converti il ​​testo selezionato in minuscolo</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Maiusc</keycap> <keycap>U</keycap>
</keycombo></entry>

          <entry>Converti il ​​testo selezionato in maiuscolo</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Y</keycap> </keycombo></entry>

          <entry>Ripeti l'azione precedentemente annullata</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Z</keycap> </keycombo></entry>

          <entry>Annulla l'ultima azione</entry>
        </row>
      </tbody>
    </tgroup>
  </table>

  <table>
    <title>Navigazione e unione delle differenze (modalità normale)</title>

    <tgroup cols="2">
      <thead>
        <row>
          <entry>Chiavi</entry>

          <entry>Funzione</entry>
        </row>
      </thead>

      <tbody>
        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Home</keycap> </keycombo></entry>

          <entry>Vai alla prima differenza</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Fine</keycap> </keycombo></entry>

          <entry>Vai all'ultima differenza</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Invio</keycap> </keycombo></entry>

          <entry>Vai alla differenza attuale o seleziona la differenza</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Freccia su</keycap> </keycombo></entry>

          <entry>Vai alla differenza precedente</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Freccia giù</keycap> </keycombo></entry>

          <entry>Vai alla differenza successiva</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Maiusc</keycap> <keycap>Freccia
su</keycap> </keycombo></entry>

          <entry>Vai al conflitto precedente</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Maiusc</keycap> <keycap>Freccia
giù</keycap> </keycombo></entry>

          <entry>Vai al conflitto successivo</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Freccia sinistra</keycap>
</keycombo></entry>

          <entry>Copia la differenza dal lato destro al lato sinistro</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Alt</keycap> <keycap>Freccia destra</keycap> </keycombo></entry>

          <entry>Copia la differenza dal lato sinistro al lato destro</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Alt</keycap> <keycap>Freccia
sinistra</keycap> </keycombo></entry>

          <entry>Copia la differenza dal lato destro a quello sinistro e seleziona la
differenza successiva</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Alt</keycap> <keycap>Freccia
destra</keycap> </keycombo></entry>

          <entry>Copia la differenza dal lato sinistro al lato destro e seleziona la
differenza successiva</entry>
        </row>
      </tbody>
    </tgroup>
  </table>

  <table>
    <title>Navigazione e unione delle differenze (modalità unione)</title>

    <tgroup cols="2">
      <thead>
        <row>
          <entry>Chiavi</entry>

          <entry>Funzione</entry>
        </row>
      </thead>

      <tbody>
        <row>
          <entry><keycap>Freccia su</keycap></entry>

          <entry>Vai alla differenza precedente</entry>
        </row>

        <row>
          <entry><keycap>Freccia giù</keycap></entry>

          <entry>Vai alla differenza successiva</entry>
        </row>

        <row>
          <entry><keycap>Freccia sinistra</keycap></entry>

          <entry>Copia la differenza dal lato destro al lato sinistro</entry>
        </row>

        <row>
          <entry><keycap>Freccia destra</keycap></entry>

          <entry>Copia la differenza dal lato sinistro al lato destro</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Alt</keycap> <keycap>Freccia
sinistra</keycap> </keycombo></entry>

          <entry>Copia la differenza dal lato destro a quello sinistro e seleziona la
differenza successiva</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Alt</keycap> <keycap>Freccia
destra</keycap> </keycombo></entry>

          <entry>Copia la differenza dal lato sinistro al lato destro e seleziona la
differenza successiva</entry>
        </row>
      </tbody>
    </tgroup>
  </table>

  <table>
    <title>Trova e sostituisci</title>

    <tgroup cols="2">
      <thead>
        <row>
          <entry>Chiavi</entry>

          <entry>Funzione</entry>
        </row>
      </thead>

      <tbody>
        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>F</keycap> </keycombo></entry>

          <entry>Trova testo (apre la finestra di dialogo Trova)</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>H</keycap> </keycombo></entry>

          <entry>Sostituisci testo (apre la finestra di dialogo Sostituisci)</entry>
        </row>

        <row>
          <entry><keycap>F3</keycap></entry>

          <entry>Trova successivo</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Maiusc</keycap> <keycap>F3</keycap> </keycombo></entry>

          <entry>Trova precedente</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>F3</keycap> </keycombo></entry>

          <entry>Trova il testo selezionato nel file</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Maiusc</keycap> <keycap>F3</keycap>
</keycombo></entry>

          <entry>Trova il testo selezionato verso l'alto nel file</entry>
        </row>
      </tbody>
    </tgroup>
  </table>

  <table>
    <title>Segnalibri</title>

    <tgroup cols="2">
      <thead>
        <row>
          <entry>Chiavi</entry>

          <entry>Funzione</entry>
        </row>
      </thead>

      <tbody>
        <row>
          <entry><keycombo> <keycap>F2</keycap> </keycombo></entry>

          <entry>Segnalibro successivo</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Maiusc</keycap> <keycap>F2</keycap> </keycombo></entry>

          <entry>Segnalibro precedente</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>F2</keycap> </keycombo></entry>

          <entry>Attiva/disattiva segnalibro</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>Maiusc</keycap> <keycap>F2</keycap>
</keycombo></entry>

          <entry>Cancella tutti i segnalibri</entry>
        </row>

      </tbody>
    </tgroup>
  </table>

  <table>
    <title>Zoom</title>

    <tgroup cols="2">
      <thead>
        <row>
          <entry>Chiavi</entry>

          <entry>Funzione</entry>
        </row>
      </thead>

      <tbody>
        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>+</keycap> </keycombo></entry>

          <entry>Aumenta la dimensione del testo</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>-</keycap> </keycombo></entry>

          <entry>Diminuisci la dimensione del testo</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <keycap>*</keycap> </keycombo></entry>

          <entry>Ripristina lo zoom del testo alle dimensioni predefinite</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <mousebutton>Rotellina del mouse
su</mousebutton> </keycombo></entry>

          <entry>Aumenta la dimensione del testo</entry>
        </row>

        <row>
          <entry><keycombo> <keycap>Ctrl</keycap> <mousebutton>Rotella del mouse
giù</mousebutton> </keycombo></entry>

          <entry>Diminuisci la dimensione del testo</entry>
        </row>
      </tbody>
    </tgroup>
  </table>
</appendix>
