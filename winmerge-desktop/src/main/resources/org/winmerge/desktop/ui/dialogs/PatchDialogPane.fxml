<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>

<DialogPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.winmerge.desktop.ui.dialogs.PatchDialogController">
    <content>
        <GridPane hgap="10.0" vgap="10.0" prefWidth="640.0">
            <padding>
                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
            </padding>
            <columnConstraints>
                <ColumnConstraints minWidth="160.0" prefWidth="170.0"/>
                <ColumnConstraints minWidth="360.0" hgrow="ALWAYS"/>
            </columnConstraints>
            <children>
                <Label text="%IDS_PATCH_DIALOG_FILE1" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="leftFileCombo" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="%IDS_PATCH_DIALOG_FILE2" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ComboBox fx:id="rightFileCombo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="%IDS_PATCH_DIALOG_RESULT" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="resultFileCombo" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="%IDS_PATCH_DIALOG_STYLE" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <ComboBox fx:id="styleCombo" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="%IDS_PATCH_DIALOG_CONTEXT" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="contextLinesField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <CheckBox fx:id="copyToClipboardCheckBox" text="%IDS_PATCH_DIALOG_COPY" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                <CheckBox fx:id="appendToFileCheckBox" text="%IDS_PATCH_DIALOG_APPEND" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                <CheckBox fx:id="openInEditorCheckBox" text="%IDS_PATCH_DIALOG_OPEN_EDITOR" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                <CheckBox fx:id="includeCommandLineCheckBox" text="%IDS_PATCH_DIALOG_INCLUDE_CMD" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

                <Label fx:id="validationLabel" GridPane.rowIndex="9" GridPane.columnIndex="1" style="-fx-text-fill: #B00020;" wrapText="true"/>
            </children>
        </GridPane>
    </content>
</DialogPane>
