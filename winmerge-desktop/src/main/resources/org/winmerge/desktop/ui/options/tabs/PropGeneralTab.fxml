<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_LEFT" spacing="10.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.winmerge.desktop.ui.options.tabs.PropGeneralTab">
    <children>
        <Label text="General options" style="-fx-font-size: 14; -fx-font-weight: bold;" />
        <CheckBox fx:id="automaticRescanCheckBox" mnemonicParsing="false" text="Enable automatic rescan after file system changes" />
        <CheckBox fx:id="scrollToFirstCheckBox" mnemonicParsing="false" text="Scroll to first difference" />
        <CheckBox fx:id="scrollToFirstInlineDiffCheckBox" mnemonicParsing="false" text="Scroll to first inline difference" />
        <CheckBox fx:id="verifyOpenPathsCheckBox" mnemonicParsing="false" text="Verify paths when opening files" />
        <CheckBox fx:id="preserveFileTimesCheckBox" mnemonicParsing="false" text="Preserve file timestamps when saving" />
        <CheckBox fx:id="showSelectFolderOnStartupCheckBox" mnemonicParsing="false" text="Show select-folder dialog on startup" />
        <CheckBox fx:id="closeWithOkCheckBox" mnemonicParsing="false" text="Close dialog when OK is pressed" />

        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label text="Single-instance mode:" />
                <Spinner fx:id="singleInstanceModeSpinner" prefWidth="100.0" />
            </children>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label text="Auto-reload mode:" />
                <Spinner fx:id="autoReloadModeSpinner" prefWidth="100.0" />
            </children>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label text="Selected language:" />
                <TextField fx:id="selectedLanguageField" promptText="e.g. en_US" HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
    </padding>
</VBox>
