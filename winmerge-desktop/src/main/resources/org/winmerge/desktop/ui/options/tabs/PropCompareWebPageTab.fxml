<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="contentRoot" alignment="TOP_LEFT" spacing="10.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.winmerge.desktop.ui.options.tabs.PropCompareWebPageTab">
    <children>
        <Label text="Compare web page options" style="-fx-font-size: 14; -fx-font-weight: bold;" />
        <CheckBox text="Use separate user-data folder per pane" userData="bool|options.compareWebPage.userDataFolderPerPane|false" />
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label text="User-data folder type:" />
                <Spinner prefWidth="90.0" userData="int|options.compareWebPage.userDataFolderType|0|0|2" />
            </children>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label text="Include URL patterns:" />
                <TextField HBox.hgrow="ALWAYS" userData="string|options.compareWebPage.urlPatternInclude|*" />
            </children>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label text="Exclude URL patterns:" />
                <TextField HBox.hgrow="ALWAYS" userData="string|options.compareWebPage.urlPatternExclude|" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
    </padding>
</VBox>
