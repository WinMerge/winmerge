<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="contentRoot" alignment="TOP_LEFT" spacing="10.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.winmerge.desktop.ui.options.tabs.PropEditorCompareMergeTab">
    <children>
        <Label text="Editor Compare/Merge options" style="-fx-font-size: 14; -fx-font-weight: bold;" />
        <CheckBox mnemonicParsing="false" text="Automatic rescan" userData="bool|options.general.automaticRescan|true" />
        <CheckBox mnemonicParsing="false" text="Enable line differences" userData="bool|options.compareMerge.viewLineDifferences|false" />
        <CheckBox mnemonicParsing="false" text="Break line differences on words" userData="bool|options.compareMerge.breakOnWords|false" />
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label text="Copy granularity:" />
                <Spinner prefWidth="100.0" userData="int|options.compareMerge.copyGranularity|0|0|3" />
            </children>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label text="Break type:" />
                <Spinner prefWidth="100.0" userData="int|options.compareMerge.breakType|0|0|1" />
            </children>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label text="Word separators:" />
                <TextField HBox.hgrow="ALWAYS" userData="string|options.compareMerge.breakSeparators|.,;:" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
    </padding>
</VBox>
