<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.winmerge.desktop.ui.dialogs.SubstitutionFiltersDialogController"
      spacing="10.0"
      prefWidth="760.0"
      prefHeight="420.0">
    <children>
        <CheckBox fx:id="enabledCheck" text="%IDS_SUBSTITUTION_FILTERS_ENABLED" />

        <TableView fx:id="filtersTable" VBox.vgrow="ALWAYS" editable="true">
            <columns>
                <TableColumn fx:id="enabledColumn" text="%IDS_FILTER_DIALOG_ENABLED" prefWidth="80.0" />
                <TableColumn fx:id="findWhatColumn" text="%IDS_SUBSTITUTION_FILTERS_FIND_WHAT" prefWidth="180.0" />
                <TableColumn fx:id="replaceWithColumn" text="%IDS_SUBSTITUTION_FILTERS_REPLACE_WITH" prefWidth="180.0" />
                <TableColumn fx:id="regexColumn" text="%IDS_SUBSTITUTION_FILTERS_REGEXP" prefWidth="90.0" />
                <TableColumn fx:id="caseSensitiveColumn" text="%IDS_SUBSTITUTION_FILTERS_CASE" prefWidth="90.0" />
                <TableColumn fx:id="wholeWordColumn" text="%IDS_SUBSTITUTION_FILTERS_WHOLE_WORD" prefWidth="110.0" />
            </columns>
        </TableView>

        <HBox spacing="8.0" alignment="CENTER_RIGHT">
            <children>
                <Button text="%IDS_FILTER_DIALOG_ADD" onAction="#onAddClicked" />
                <Button fx:id="removeButton" text="%IDS_FILTER_DIALOG_REMOVE" onAction="#onRemoveClicked" />
                <Button fx:id="clearButton" text="%IDS_FILTER_DIALOG_CLEAR" onAction="#onClearClicked" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
    </padding>
</VBox>
