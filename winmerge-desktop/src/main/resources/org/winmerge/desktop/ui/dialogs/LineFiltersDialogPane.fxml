<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.winmerge.desktop.ui.dialogs.LineFiltersDialogController"
      spacing="10.0"
      prefWidth="580.0"
      prefHeight="420.0">
    <children>
        <CheckBox fx:id="ignoreRegExpCheck" text="%IDS_FILTERLINE_REGEXP" />
        <ListView fx:id="filtersList" VBox.vgrow="ALWAYS" />
        <HBox spacing="8.0" alignment="CENTER_RIGHT">
            <children>
                <Button text="%IDS_FILTER_DIALOG_ADD" onAction="#onAddClicked" />
                <Button fx:id="editButton" text="%IDS_FILTER_DIALOG_EDIT" onAction="#onEditClicked" />
                <Button fx:id="removeButton" text="%IDS_FILTER_DIALOG_REMOVE" onAction="#onRemoveClicked" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
    </padding>
</VBox>
