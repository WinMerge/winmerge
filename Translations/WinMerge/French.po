#: Merge.rc:5457
msgid ""
"# Regex replacement list\r\n"
"# Format: regex<TAB>replacement\r\n"
"# Backreferences like $1, $2 are supported\r\n"
"\r\n"
"(\\d{4})-(\\d{2})-(\\d{2})\t$1_$2_$3\r\n"
msgstr ""
"# Liste de remplacement regex\n"
"# Format : regex<TAB>remplacement\n"
"# Les références arrières comme $1, $2 sont prises en charge\r\n"
"\r\n"
"(\\d{4})-(\\d{2})-(\\d{2})\t$1_$2_$3\n"
"\v\n"

#. IDS_STRING_REPLACE_LIST_TEMPLATE
#: Merge.rc:5458
msgid ""
"# Replacement list\r\n"
"# Format: search<TAB>replacement\r\n"
"# Lines starting with # are ignored\r\n"
"\r\n"
"from1\tto1\r\n"
"from2\tto2\r\n"
msgstr ""
"# Liste de remplacement\n"
"# Format : recherche <TAB>remplacement\r\n"
"# Les lignes commençant par # sont ignorées\r\n"
