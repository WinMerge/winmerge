#. IDS_PLUGIN_DESCRIPTION9
#: Strings.rc:123
msgid ""
"Replace text.\r\n"
"Usage: Replace [-i] [-e] FIND REPLACE\r\n"
" or: Replace -s\r\n"
" FIND - text to find\r\n"
" REPLACE - text to replace\r\n"
" -i - ignore case (only for -e)\r\n"
" -e - regex\r\n"
" -s - use Substitution Filters"
msgstr ""
"取代文字。\r\n"
"用法：Replace [-i] [-e] FIND REPLACE\r\n"
"或：Replace -s\r\n"
"FIND - 要尋找的文字\r\n"
"REPLACE - 要取代的文字\r\n"
"-i - 忽略大小寫（僅適用於 -e）\r\n"
"-e - 正規表示式\r\n"
"-s - 使用取代篩選器"

#: Strings.rc:125
#, c-format
msgid ""
"Apply filter. \r\n"
"Usage: ExecFilterCommand COMMAND\r\n"
" COMMAND - command to execute. %1 = filename."
msgstr ""
"應用篩選器命令。\r\n"
"用法：ExecFilterCommand COMMAND\r\n"
"COMMAND - 要執行的命令。命令中的 %1 會被替換為檔案名稱。"

#: Strings.rc:127
msgid ""
"Tokenize. \r\n"
"Usage: Tokenize PATTERNS\r\n"
" PATTERNS - regex (e.g. [^\\w]+)"
msgstr ""
"選取的文字進行分詞。\r\n"
"用法：Tokenize PATTERNS\r\n"
" PATTERNS - 用於分詞的正則表示式。（例如：[^\\w]+）"

#. IDS_PLUGIN_DESCRIPTION12
#: Strings.rc:128
msgid "Trim spaces"
msgstr "修剪空格"

#: Strings.rc:130
msgid ""
"Select columns.\r\n"
"Usage: SelectColumns RANGES\r\n"
" or: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" RANGES - column ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -g - enable global flag\r\n"
" -e - use PATTERNS"
msgstr ""
"選取某些欄位。\r\n"
"用法：SelectColumns RANGES\r\n"
" 或：SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" RANGES - 要選取的欄位範圍列表。例如：-3,5-10,30-\r\n"
" PATTERNS - 正則表示式\r\n"
" -v - 選取不符合條件的欄位\r\n"
" -i - 忽略大小寫\r\n"
" -g - 啟用全域標誌\r\n"
" -e - 使用 PATTERNS 進行匹配"

#: Strings.rc:132
msgid ""
"Select lines.\r\n"
"Usage: SelectLines RANGES\r\n"
" or: SelectLines [-v] [-i] -e PATTERNS\r\n"
" RANGES - line ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -e - use PATTERNS"
msgstr ""
"選取某些行。\r\n"
"用法：SelectLines RANGES\r\n"
" 或：SelectLines [-v] [-i] -e PATTERNS\r\n"
" RANGES - 要選取的行範圍列表。例如：-3,5-10,30-\r\n"
" PATTERNS - 正則表示式\r\n"
" -v - 選取不符合條件的行\r\n"
" -i - 忽略大小寫\r\n"
" -e - 使用 PATTERNS 進行匹配"

