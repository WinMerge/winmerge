msgstr "Заменить текст.\r\nИспользование: Replace [-i] [-e] FIND REPLACE\r\n   или: Replace -s\r\n FIND - текст для поиска\r\n REPLACE - текст для замены\r\n -i - игнорировать регистр (только с -e)\r\n -e - рассматривать указанный текст как регулярное выражение\r\n  -s - заменить, используя шаблоны фильтров подмены"

#: Strings.rc:125
#, c-format
msgid "Apply filter. \r\nUsage: ExecFilterCommand COMMAND\r\n COMMAND - command to execute. %1 = filename."
msgstr "Применить фильтрацию. \r\nИспользование: ExecFilterCommand COMMAND\r\n COMMAND - команда для выполнения. %1 в команде заменяется именем файла."

#: Strings.rc:127
msgid "Tokenize. \r\nUsage: Tokenize PATTERNS\r\n PATTERNS - regex (e.g. [^\\w]+)"
msgstr "Токенизировать выбранное. \r\nИспользование: Tokenize PATTERNS\r\n PATTERNS - регулярное выражение токенизации. (например, [^\\w]+)"

