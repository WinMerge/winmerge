#. IDS_PLUGIN_DESCRIPTION9
#: Strings.rc:123
msgid "Replace text.\r\nUsage: Replace [-i] [-e] FIND REPLACE\r\n or: Replace -s\r\n FIND - text to find\r\n REPLACE - text to replace\r\n -i - ignore case (only for -e)\r\n -e - regex\r\n -s - use Substitution Filters"
msgstr "Substituir texto.\r\nUso: Replace [-i] [-e] FIND REPLACE\r\n ou: Replace -s\r\n FIND - texto a encontrar\r\n REPLACE - texto para substituir\r\n  -i - ignorar maiúsculas/minúsculas (apenas para -e)\r\n -e - regex\r\n -s - usar Filtros de Substituição"

#: Strings.rc:125
#, c-format
msgid "Apply filter. \r\nUsage: ExecFilterCommand COMMAND\r\n COMMAND - command to execute. %1 = filename."
msgstr "Aplicar filtro. \r\nUso: ExecFilterCommand COMMAND\r\n COMMAND - comando a executar. %1 = nome do arquivo."

