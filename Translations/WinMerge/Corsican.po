#. IDS_REGEX_REPLACE_LIST_TEMPLATE
#: Merge.rc:5435
msgid ""
"# Regex replacement list\r\n"
"# Format: regex<TAB>replacement\r\n"
"# Backreferences like $1, $2 are supported\r\n"
"\r\n"
"(\\d{4})-(\\d{2})-(\\d{2})\t$1_$2_$3\r\n"
msgstr ""
"# Lista di rimpiazzamentu regex\\r\n"
"# Furmatu : regex<TAB>rimpiazzamentu\\r\n"
"# E referenze anteriore cum’è $1, $2 sò accettate\\r\n"
"\\r\n"
"(\\d{4})-(\\d{2})-(\\d{2})\t$1_$2_$3\\r\n"

#. IDS_STRING_REPLACE_LIST_TEMPLATE
#: Merge.rc:5436
msgid ""
"# Replacement list\r\n"
"# Format: search<TAB>replacement\r\n"
"# Lines starting with # are ignored\r\n"
"\r\n"
"from1\tto1\r\n"
"from2\tto2\r\n"
msgstr ""
"# Lista di rimpiazzamentu\\r\n"
"# Furmatu : search<TAB>rimpiazzamentu\\r\n"
"# E linee chì principianu cù # sò ignurate\\r\n"
"\\r\n"
"da1\tà1\\r\n"
"da2\tà2\\r\n"

