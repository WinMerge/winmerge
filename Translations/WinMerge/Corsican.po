#. IDS_PLUGIN_DESCRIPTION9
#: Strings.rc:123
msgid ""
"Replace text.\r\n"
"Usage: Replace [-i] [-e] FIND REPLACE\r\n"
" or: Replace -s\r\n"
" FIND - text to find\r\n"
" REPLACE - text to replace\r\n"
" -i - ignore case (only for -e)\r\n"
" -e - regex\r\n"
" -s - use Substitution Filters"
msgstr ""
"Rimpiazzà u testu.\r\n"
"Aghjovu : Replace [-i] [-e] CIRCÀ RIMPIAZZÀ\r\n"
"   o : Replace -s\r\n"
"  CIRCÀ - testu à circà\r\n"
"  RIMPIAZZÀ - testu à rimpiazzà\r\n"
"  -i - ignurà a cassa (solu per -e)\r\n"
"  -e - espressione regex\r\n"
"  -s - impiegà filtri di sustituzione"

#: Strings.rc:125
#, c-format
msgid ""
"Apply filter. \r\n"
"Usage: ExecFilterCommand COMMAND\r\n"
" COMMAND - command to execute. %1 = filename."
msgstr ""
"Appiecà un filtru.\r\n"
"Aghjovu : ExecFilterCommand CUMANDA\r\n"
"  CUMANDA - cumanda à lancià. %1 = nome di schedariu."

#: Strings.rc:127
msgid ""
"Tokenize. \r\n"
"Usage: Tokenize PATTERNS\r\n"
" PATTERNS - regex (e.g. [^\\w]+)"
msgstr ""
"Segmentazione.\r\n"
"Aghjovu : Tokenize MUDELLI\r\n"
"  MUDELLI - espressione regulare (per indettu [^\\w]+)"

#. IDS_PLUGIN_DESCRIPTION12
#: Strings.rc:128
msgid "Trim spaces"
msgstr "Ammuzzà i spazii"

#: Strings.rc:130
msgid ""
"Select columns.\r\n"
"Usage: SelectColumns RANGES\r\n"
" or: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" RANGES - column ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -g - enable global flag\r\n"
" -e - use PATTERNS"
msgstr ""
"Selezziunà culonne.\r\n"
"Aghjovu : SelectColumns SERIE\r\n"
" o : SelectColumns [-v] [-i] [-g] -e MUDELLI\r\n"
" SERIE - lista di serie di culonne (-3,5-10,30-)\r\n"
" MUDELLI - espressione regulare\r\n"
" -v - selezziunà ciò chì ùn currisponde micca\r\n"
" -i - ignurà a cassa\r\n"
" -g - attivà a bandera glubale\r\n"
" -e - impiegà MUDELLI"

#: Strings.rc:132
msgid ""
"Select lines.\r\n"
"Usage: SelectLines RANGES\r\n"
" or: SelectLines [-v] [-i] -e PATTERNS\r\n"
" RANGES - line ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -e - use PATTERNS"
msgstr ""
"Selezziunà linee.\r\n"
"Aghjovu : SelectLines SERIE\r\n"
" o : SelectLines [-v] [-i] -e MUDELLI\r\n"
" SERIE - lista di serie di linee (-3,5-10,30-)\n"
" MUDELLI - espressione regulare\n"
" -v - selezziunà ciò chì ùn currisponde micca\n"
" -i - ignurà a cassa\n"
" -g - attivà a bandera glubale\n"
" -e - impiegà MUDELLI"

