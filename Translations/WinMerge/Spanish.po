#. IDS_PLUGIN_DESCRIPTION9
#: Strings.rc:123
msgid ""
"Replace text.\r\n"
"Usage: Replace [-i] [-e] FIND REPLACE\r\n"
" or: Replace -s\r\n"
" FIND - text to find\r\n"
" REPLACE - text to replace\r\n"
" -i - ignore case (only for -e)\r\n"
" -e - regex\r\n"
" -s - use Substitution Filters"
msgstr ""
"Sustituir un texto por otro.\r\n"
"Uso: Replace [-i] [-e] BUSCAR SUSTITUIR\r\n"
" or: Replace -s\r\n"
"  BUSCAR    - Texto a buscar\r\n"
"  SUSTITUIR - Texto a sustituir\r\n"
"  -i - Ignora argumentos (solo para -e)\r\n"
"  -e - Trata el texto especificado como una expresión regular\r\n"
" -s - use Substitution Filters"

#: Strings.rc:125
#, c-format
msgid ""
"Apply filter. \r\n"
"Usage: ExecFilterCommand COMMAND\r\n"
" COMMAND - command to execute. %1 = filename."
msgstr ""
"Aplicar comando de filtro. \r\n"
"Uso: comando ExecFilter COMANDO\r\n"
"  COMANDO - Comando a ejecutar. %1 en el comando se sustituye con el nombre del archivo."

#: Strings.rc:127
msgid ""
"Tokenize. \r\n"
"Usage: Tokenize PATTERNS\r\n"
" PATTERNS - regex (e.g. [^\\w]+)"
msgstr ""
"Selección de tokens. \r\n"
"Uso: Tokenizar PATRONES\r\n"
"  PATRONES - Expresión regular para la tokenización (ejemplo [^\\\\w]+)"

#. IDS_PLUGIN_DESCRIPTION12
#: Strings.rc:128
msgid "Trim spaces"
msgstr "Recortar espacios"

#: Strings.rc:130
msgid ""
"Select columns.\r\n"
"Usage: SelectColumns RANGES\r\n"
" or: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" RANGES - column ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -g - enable global flag\r\n"
" -e - use PATTERNS"
msgstr ""
"Seleccionar algunas columnas.\r\n"
"Uso: SelectColumns RANGOS\r\n"
"   o: SelectColumns [-v] [-i] [-g] -e PATRONES\r\n"
"  RANGOS   - Lista de rangos de columnas a seleccionar. (ejemplo -3,5-10,30-)\r\n"
"  PATRONES - Expresión regular \r\n"
"  -v - Seleccionar columnas no coincidentes\r\n"
"  -i - Ignorar mayúsculas/minúsculas\r\n"
"  -g - Habilitar indicador global\r\n"
"  -e - Usar PATRONES para coincidencias"

#: Strings.rc:132
msgid ""
"Select lines.\r\n"
"Usage: SelectLines RANGES\r\n"
" or: SelectLines [-v] [-i] -e PATTERNS\r\n"
" RANGES - line ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -e - use PATTERNS"
msgstr ""
"Seleccionar algunas líneas.\r\n"
"Uso: SelectLines RANGOS\r\n"
"   o: SelectLines [-v] [-i] -e PATRONES\r\n"
"  RANGOS   - Lista de rangos de líneas a seleccionar (ejemplo -3,5-10,30-)\r\n"
"  PATRONES - Expresión regular\r\n"
"  -v - Seleccionar líneas no coincidentes\r\n"
"  -i - Ignorar mayúsculas /minúsculas\r\n"
"  -e - Usar PATRONES para coincidencias"

