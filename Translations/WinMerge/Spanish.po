#. IDS_REGEX_REPLACE_LIST_TEMPLATE
#: Merge.rc:5729
msgid ""
"# Regex replacement list\r\n"
"# Format: regex<TAB>replacement\r\n"
"# Backreferences like $1, $2 are supported\r\n"
"\r\n"
"(\\d{4})-(\\d{2})-(\\d{2})\t$1_$2_$3\r\n"
msgstr ""
"# Lista de sustituciones de expresiones regulares\r\n"
"# Formato: expresión regular<TAB>sustitución\r\n"
"# Se admiten referencias hacia atrás como $1, $2\r\n"
"\r\n"
"(\\d{4})-(\\d{2})-(\\d{2})\t$1_$2_$3\r\n"

#. IDS_STRING_REPLACE_LIST_TEMPLATE
#: Merge.rc:5730
msgid ""
"# Replacement list\r\n"
"# Format: search<TAB>replacement\r\n"
"# Lines starting with # are ignored\r\n"
"\r\n"
"from1\tto1\r\n"
"from2\tto2\r\n"
msgstr ""
"# Lista de sustituciones\r\n"
"# Formato: búsqueda<TAB>sustitución\r\n"
"# Las líneas que empiezan por # se ignoran\r\n"
"\r\n"
"desde1\thasta1\r\n"
"desde2\thasta2\r\n"

