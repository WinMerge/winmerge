#. IDS_PLUGIN_DESCRIPTION9
#: Strings.rc:123
msgid ""
"Replace text.\r\n"
"Usage: Replace [-i] [-e] FIND REPLACE\r\n"
" or: Replace -s\r\n"
" FIND - text to find\r\n"
" REPLACE - text to replace\r\n"
" -i - ignore case (only for -e)\r\n"
" -e - regex\r\n"
" -s - use Substitution Filters"
msgstr ""
"Sustituir un texto por otro.\r\n"
"Uso: Replace [-i] [-e] FIND REPLACE\r\n"
" o: Replace -s\r\n"
" FIND - Texto a buscar\r\n"
" REPLACE - Texto a sustituir\r\n"
" -i - Ignora mayúsculas y minúsculas (solo para -e)\r\n"
" -e - Trata el texto especificado como una expresión regular\r\n"
" -s - Usa filtros de sustitución"

#: Strings.rc:125
#, c-format
msgid ""
"Apply filter. \r\n"
"Usage: ExecFilterCommand COMMAND\r\n"
" COMMAND - command to execute. %1 = filename."
msgstr ""
"Aplicar comando de filtro. \r\n"
"Uso: comando ExecFilter COMAND\r\n"
"  COMAND - Comando a ejecutar. %1 en el comando se sustituye con el nombre del archivo."

#: Strings.rc:127
msgid ""
"Tokenize. \r\n"
"Usage: Tokenize PATTERNS\r\n"
" PATTERNS - regex (e.g. [^\\w]+)"
msgstr ""
"Selección de tokens. \r\n"
"Uso: Tokenizar PATTERNS\r\n"
"  PATTERNS - Expresión regular para la tokenización (ejemplo [^\\w]+)"

#. IDS_PLUGIN_DESCRIPTION12
#: Strings.rc:128
msgid "Trim spaces"
msgstr "Eliminar espacios"

#: Strings.rc:130
msgid ""
"Select columns.\r\n"
"Usage: SelectColumns RANGES\r\n"
" or: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" RANGES - column ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
