#. IDS_PLUGIN_DESCRIPTION9
#: Strings.rc:123
msgid ""
"Replace text.\r\n"
"Usage: Replace [-i] [-e] FIND REPLACE\r\n"
" or: Replace -s\r\n"
" FIND - text to find\r\n"
" REPLACE - text to replace\r\n"
" -i - ignore case (only for -e)\r\n"
" -e - regex\r\n"
" -s - use Substitution Filters"
msgstr ""
"Замінити текст.\r\n"
"Використання: Replace [-i] [-e] FIND REPLACE\r\n"
" або: Replace -s\r\n"
" FIND - текст для пошуку\r\n"
" REPLACE - текст для заміни\r\n"
" -i - ігнорувати регістр (тільки для -e)\r\n"
" -e - регулярний вираз\r\n"
" -s - використовувати фільтри підміни"

#: Strings.rc:125
#, c-format
msgid ""
"Apply filter. \r\n"
"Usage: ExecFilterCommand COMMAND\r\n"
" COMMAND - command to execute. %1 = filename."
msgstr ""
"Застосувати фільтр.\r\n"
"Використання: ExecFilterCommand COMMAND\r\n"
" COMMAND - команда для виконання. %1 = ім'я файлу."

#: Strings.rc:127
msgid ""
"Tokenize. \r\n"
"Usage: Tokenize PATTERNS\r\n"
" PATTERNS - regex (e.g. [^\\w]+)"
msgstr ""
"Токенізувати.\r\n"
"Використання: Tokenize PATTERNS\r\n"
" PATTERNS - регулярний вираз (наприклад, [^\\w]+)"

#. IDS_PLUGIN_DESCRIPTION12
#: Strings.rc:128
msgid "Trim spaces"
msgstr "Обрізати пробіли"

#: Strings.rc:130
msgid ""
"Select columns.\r\n"
"Usage: SelectColumns RANGES\r\n"
" or: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" RANGES - column ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -g - enable global flag\r\n"
" -e - use PATTERNS"
msgstr ""
"Вибрати стовпці.\r\n"
"Використання: SelectColumns RANGES\r\n"
" або: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" RANGES - діапазони стовпців (-3,5-10,30-)\r\n"
" PATTERNS - регулярний вираз\r\n"
" -v - вибирати ті, що не підходять\r\n"
" -i - ігнорувати регістр\r\n"
" -g - увімкнути глобальний прапорець\r\n"
" -e - використати PATTERNS"

#: Strings.rc:132
msgid ""
"Select lines.\r\n"
"Usage: SelectLines RANGES\r\n"
" or: SelectLines [-v] [-i] -e PATTERNS\r\n"
" RANGES - line ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -e - use PATTERNS"
msgstr ""
"Вибрати рядки.\r\n"
"Використання: SelectLines RANGES\r\n"
" або: SelectLines [-v] [-i] -e PATTERNS\r\n"
" RANGES - діапазони рядків (-3,5-10,30-)\r\n"
" PATTERNS - регулярний вираз\r\n"
" -v - вибирати ті, що не підходять\r\n"
" -i - ігнорувати регістр\r\n"
" -e - використати PATTERNS"

