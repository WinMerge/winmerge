#. IDS_PLUGIN_DESCRIPTION9
#: Strings.rc:123
msgid ""
"Replace text.\r\n"
"Usage: Replace [-i] [-e] FIND REPLACE\r\n"
" or: Replace -s\r\n"
" FIND - text to find\r\n"
" REPLACE - text to replace\r\n"
" -i - ignore case (only for -e)\r\n"
" -e - regex\r\n"
" -s - use Substitution Filters"
msgstr ""
"உரையை வேறொரு உரையுடன் மாற்று.\r\n"
"பயன்பாடு: [-i] மாற்று [-e] மாற்றீட்டைக் கண்டுபிடி\r\n"
" or: Replace -s\r\n"
"கண்டுபிடி - கண்டுபிடிக்க உரை\r\n"
" REPLACE - பதிலாக உரை\r\n"
" -i - புறக்கணிப்பு வழக்கை (-eக்கு மட்டும்)\r\n"
" -e - குறிப்பிட்ட உரையை வழக்கமான வெளிப்பாடாகக் கருதுங்கள்\r\n"
" -s - replace using Substitution Filters patterns"

#: Strings.rc:125
#, c-format
msgid ""
"Apply filter. \r\n"
"Usage: ExecFilterCommand COMMAND\r\n"
" COMMAND - command to execute. %1 = filename."
msgstr ""
"வடிப்பான் கட்டளையைப் பயன்படுத்து. \r\n"
"பயன்பாடு: ExecFilterCommand COMMAND\r\n"
" COMMAND - செயல்படுத்துவதற்கான கட்டளை. கட்டளையில் உள்ள % 1 கோப்புப் பெயருடன் மாற்றப்பட்டது."

#: Strings.rc:127
msgid ""
"Tokenize. \r\n"
"Usage: Tokenize PATTERNS\r\n"
" PATTERNS - regex (e.g. [^\\w]+)"
msgstr ""
"டோக்கனைச் தேர்வு. \r\n"
"பயன்பாடு: டோக்கனைச் பேட்டர்ன்ச்\r\n"
" வடிவங்கள் - டோக்கனைச் செய்வதற்கான வழக்கமான வெளிப்பாடு. (எ.கா. [^\\w]+)"

#. IDS_PLUGIN_DESCRIPTION12
#: Strings.rc:128
msgid "Trim spaces"
msgstr "இடங்களை ஒழுங்கமைக்கவும்"

#: Strings.rc:130
msgid ""
"Select columns.\r\n"
"Usage: SelectColumns RANGES\r\n"
" or: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" RANGES - column ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -g - enable global flag\r\n"
" -e - use PATTERNS"
msgstr ""
"சில நெடுவரிசைகளைத் தேர்ந்தெடு.\r\n"
"பயன்பாடு: தேர்ந்தெடு நெடுவரிசைகள் RANGES\r\n"
"அல்லது: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" வரம்புகள் - தேர்ந்தெடுக்க வேண்டிய நெடுவரிசை வரம்புகளின் பட்டியல். (எ.கா. -3,5-10,30-)\r\n"
" வடிவங்கள் - வழக்கமான வெளிப்பாடு\r\n"
" -v - பொருந்தாத நெடுவரிசைகளைத் தேர்ந்தெடு\r\n"
" -i - புறக்கணிப்பு வழக்கை\r\n"
" -g - உலகளாவிய கொடியை இயக்கு\r\n"
" -e - பொருத்துவதற்கு PATTERNS ஐப் பயன்படுத்து"

#: Strings.rc:132
msgid ""
"Select lines.\r\n"
"Usage: SelectLines RANGES\r\n"
" or: SelectLines [-v] [-i] -e PATTERNS\r\n"
" RANGES - line ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -e - use PATTERNS"
msgstr ""
"சில வரிகளைத் தேர்ந்தெடு.\r\n"
"பயன்பாடு: தேர்ந்தெடுக்கப்பட்ட வரிகள் வரம்புகள்\r\n"
"அல்லது: SelectLines [-v] [-i] -e PATTERNS\r\n"
"வரம்புகள் - தேர்ந்தெடுக்க வேண்டிய வரி வரம்புகளின் பட்டியல். (எ.கா. -3,5-10,30-)\r\n"
" வடிவங்கள் - வழக்கமான வெளிப்பாடு\r\n"
" -v - பொருந்தாத வரிகளைத் தேர்ந்தெடு\r\n"
" -i - புறக்கணிப்பு வழக்கை\r\n"
" -e - பொருத்துவதற்கு PATTERNS ஐப் பயன்படுத்து"

