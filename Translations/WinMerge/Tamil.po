#. IDS_ERROR_INCOMPARABLE
#: Merge.rc:4417
msgid "Select two existing folders/files to compare."
msgstr ""
"ஒப்பிடுவதற்கு ஏற்கனவே உள்ள இரண்டு கோப்புறைகள் அல்லது கோப்புகளைத் "
"தேர்ந்தெடு."

#. IDS_DIRSEL_TAG
#: Merge.rc:4418
msgid "Folder Selection"
msgstr "கோப்புறை தேர்வு"

#. IDS_OPEN_FILESDIRS
#: Merge.rc:4419
msgid "Select two (or three) folders/files to compare."
msgstr ""
"ஒப்பிட இரண்டு (அல்லது மூன்று) கோப்புறைகள் அல்லது இரண்டு (அல்லது மூன்று) "
"கோப்புகளைத் தேர்ந்தெடு."

#. IDS_OPEN_LEFTINVALID
#: Merge.rc:4420
msgid "Left (1st) path is invalid!"
msgstr "இடது (1வது) பாதை தவறானது!"

#. IDS_OPEN_MIDDLEINVALID
#: Merge.rc:4421
msgid "Middle (2nd) path is invalid!"
msgstr "நடு (2வது) பாதை தவறானது!"

#. IDS_OPEN_RIGHTINVALID2
#: Merge.rc:4422
msgid "Right (2nd) path is invalid!"
msgstr "வலது (2வது) பாதை தவறானது!"

#. IDS_OPEN_RIGHTINVALID3
#: Merge.rc:4423
msgid "Right (3rd) path is invalid!"
msgstr "வலது (3வது) பாதை தவறானது!"

#. IDS_OPEN_BOTHINVALID
#: Merge.rc:4424
msgid "Both paths are invalid!"
msgstr "இரண்டு பாதைகளும் தவறானவை!"

#: Merge.rc:4426
msgid "Left (1st) and Middle (2nd) paths are invalid!"
msgstr "இடது (1வது) மற்றும் நடு (2வது) பாதைகள் தவறானவை!"

#. IDS_OPEN_LEFTRIGHTINVALID
#: Merge.rc:4427
msgid "Left (1st) and Right (3rd) paths are invalid!"
msgstr "இடது (1வது) மற்றும் வலது (3வது) பாதைகள் தவறானவை!"

#: Merge.rc:4429
msgid "Middle (2nd) and Right (3rd) paths are invalid!"
msgstr "நடு (2வது) மற்றும் வலது (3வது) பாதைகள் தவறானவை!"

#. IDS_OPEN_ALLINVALID
#: Merge.rc:4430
msgid "All paths are invalid!"
msgstr "அனைத்து பாதைகளும் தவறானவை!"

#. IDS_OPEN_UNPACKERDISABLED
#: Merge.rc:4431
msgid "Only enabled for file comparisons"
msgstr "கோப்பு ஒப்பீடுகளுக்கு மட்டும் இயக்கப்பட்டது"

#. IDS_OPEN_MISMATCH
#: Merge.rc:4432
msgid "Cannot compare file and folder!"
msgstr "கோப்பு மற்றும் கோப்புறையை ஒப்பிட முடியாது!"

#. IDS_ERROR_FILE_NOT_FOUND
#: Merge.rc:4438
#, c-format
msgid "File not found: %1"
msgstr "கோப்பு கிடைக்கவில்லை: %1"

#. IDS_ERROR_FOLDER_NOT_FOUND
#: Merge.rc:4439
#, c-format
msgid "Folder not found: %1"
msgstr ""

#. IDS_ERROR_FILE_NOT_UNPACKED
#: Merge.rc:4440
#, c-format
msgid "File not unpacked: %1"
msgstr "கோப்பு திறக்கப்படவில்லை: %1"

#. IDS_ERROR_FILEOPEN
#: Merge.rc:4441
#, c-format
msgid ""
"Cannot open file\n"
"%1\n"
"\n"
"%2"
msgstr ""
"கோப்பை திறக்க முடியவில்லை\n"
"% 1\n"
"\n"
"%2"

#. IDS_ERROR_CONF_RESOLVE
#: Merge.rc:4442
msgid "Failed to parse conflict file."
msgstr "மோதல் கோப்பை அலசுவதில் தோல்வி."

#. IDS_NOT_CONFLICT_FILE
#: Merge.rc:4443
#, c-format
msgid ""
"The file\n"
"%1\n"
"is not a conflict file."
msgstr ""
"கோப்பு\n"
"% 1\n"
"ஒரு மோதல் கோப்பு அல்ல."

#. IDS_COMPARE_LARGE_FILES
#: Merge.rc:4444
msgid ""
"Comparing large files requires significant memory.\n"
"Show only comparison results (not file contents)?"
msgstr ""
"நீங்கள் மிகப் பெரிய கோப்புகளை ஒப்பிடப் போகிறீர்கள்.\n"
"கோப்புகளின் உள்ளடக்கங்களைக் காண்பிப்பதற்கு மிகப் பெரிய அளவிலான நினைவகம் தேவைப்படுகிறது.\n"
"கோப்புகளின் உள்ளடக்கங்களைக் காட்டாமல், ஒப்பீட்டு முடிவுகளை மட்டும் காட்ட விரும்புகிறீர்களா?\n"
"\n"

#. IDS_SAVE_AS_TITLE
#: Merge.rc:4450
msgid "Save As"
msgstr "இவ்வாறு சேமி"

#. IDS_SAVE_FMT
#: Merge.rc:4451
#, c-format
msgid "Save changes to %1?"
msgstr "மாற்றங்களை %1 இல் சேமிக்கவா?"

#. IDS_SAVEREADONLY_FMT
#: Merge.rc:4452
#, c-format
msgid "%1 is read-only. Override? Or 'No' to save as new filename?"
msgstr ""
"%1 படிக்க மட்டுமே எனக் குறிக்கப்பட்டுள்ளது. படிக்க மட்டுமேயான கோப்பை மேலெழுத"
" விரும்புகிறீர்களா? (புதிய கோப்புப் பெயராகச் சேமிக்க வேண்டாம்.)"

#. IDS_ERROR_BACKUP
#: Merge.rc:4453
msgid "Error backing up file"
msgstr "கோப்பை காப்புப் பிரதி எடுப்பதில் பிழை"

#: Merge.rc:4455
#, c-format
msgid ""
"Unable to backup original file:\n"
"%1\n"
"\n"
"Continue anyway?"
msgstr ""
"அசல் கோப்பை காப்புப் பிரதி எடுக்க முடியவில்லை:\n"
"% 1\n"
"\n"
"எப்படியும் தொடரலாமா?"

#. IDS_FILESAVE_FAILED
#: Merge.rc:4456
#, c-format
msgid ""
"Saving file failed.\n"
"%1\n"
"%2\n"
"\t- Use different filename (OK)\n"
"\t- Abort (Cancel)?"
msgstr ""
"கோப்பைச் சேமிப்பதில் தோல்வி.\n"
"% 1\n"
"%2\n"
"நீங்கள் விரும்புகிறீர்களா:\n"
"\t- வேறு கோப்புப் பெயரைப் பயன்படுத்து (சரி)\n"
"\t- நிறுத்து (நீக்கறல்)?"

#: Merge.rc:4458
#, c-format
msgid ""
"Plugin '%2' cannot pack changes to left file into '%1'.\n"
"\n"
"Original unchanged. Save unpacked version?"
msgstr ""
"சொருகி '% 2' உங்கள் மாற்றங்களை இடது கோப்பில் மீண்டும் '% 1' இல் பேக் செய்ய முடியாது.\n"
"\n"
"அசல் கோப்பு மாற்றப்படாது.\n"
"\n"
"தொகுக்கப்படாத பதிப்பை வேறொரு கோப்பில் சேமிக்க விரும்புகிறீர்களா?"

#: Merge.rc:4460
#, c-format
msgid ""
"Plugin '%2' cannot pack changes to middle file into '%1'.\n"
"\n"
"Original unchanged. Save unpacked version?"
msgstr ""
"சொருகி '% 2' ஆனது நடுக் கோப்பில் நீங்கள் செய்த மாற்றங்களை மீண்டும் '% 1' இல் தொகுக்க முடியாது.\n"
"\n"
"அசல் கோப்பு மாற்றப்படாது.\n"
"\n"
"தொகுக்கப்படாத பதிப்பை வேறொரு கோப்பில் சேமிக்க விரும்புகிறீர்களா?"

#: Merge.rc:4462
#, c-format
msgid ""
"Plugin '%2' cannot pack changes to right file into '%1'.\n"
"\n"
"Original unchanged. Save unpacked version?"
msgstr ""
"சொருகி '% 2' உங்கள் மாற்றங்களை வலது கோப்பில் மீண்டும் '% 1' இல் பேக் செய்ய முடியாது.\n"
"\n"
"அசல் கோப்பு மாற்றப்படாது.\n"
"\n"
"தொகுக்கப்படாத பதிப்பை வேறொரு கோப்பில் சேமிக்க விரும்புகிறீர்களா?"

#. IDS_FILECHANGED_ONDISK
#: Merge.rc:4463
#, c-format
msgid ""
"Another application updated\n"
"%1\n"
"since WinMerge loaded it.\n"
"\n"
"Overwrite?"
msgstr ""
"மற்றொரு பயன்பாடு கோப்பு புதுப்பிக்கப்பட்டது\n"
"% 1\n"
"சாளரஒன்றிணை அதை ஏற்றியதால்.\n"
"\n"
"மாற்றப்பட்ட கோப்பை மேலெழுதவா?"

#. IDS_SAVEREADONLY_MULTI
#: Merge.rc:4464
#, c-format
msgid ""
"%1\n"
"is read-only. Override?"
msgstr ""
"% 1\n"
"படிக்க மட்டுமே என்று குறிக்கப்பட்டுள்ளது. படிக்க மட்டுமேயான உருப்படியை மேலெழுத விரும்புகிறீர்களா?"

#. IDS_FILECHANGED_RESCAN
#: Merge.rc:4465
#, c-format
msgid ""
"Another application updated\n"
"%1\n"
"since last scan.\n"
"\n"
"Reload?"
msgstr ""
"மற்றொரு பயன்பாடு கோப்பு புதுப்பிக்கப்பட்டது\n"
"% 1\n"
"கடைசியாக ச்கேன் செய்ததால்.\n"
"\n"
"மீண்டும் ஏற்றவா?"

#. IDS_SAVE_LEFT_AS
#: Merge.rc:4466
msgid "Save Left File As"
msgstr "இடது கோப்பை இவ்வாறு சேமி"

#. IDS_SAVE_MIDDLE_AS
#: Merge.rc:4467
