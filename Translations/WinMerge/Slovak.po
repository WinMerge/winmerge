#. IDS_PLUGIN_DESCRIPTION9
#: Strings.rc:123
msgid "Replace text.\r\nUsage: Replace [-i] [-e] FIND REPLACE\r\n or: Replace -s\r\n FIND - text to find\r\n REPLACE - text to replace\r\n -i - ignore case (only for -e)\r\n -e - regex\r\n -s - use Substitution Filters"
msgstr ""
"Nahradenie textu iným textom.\r\n"
"Použitie: Replace [-i] [-e] FIND REPLACE\r\n"
" or: Replace -s\r\n"
"  FIND - text, ktorý sa má nájsť\r\n"
"  REPLACE - text, ktorý sa má nahradiť\r\n"
"  -i - ignorovať veľké a malé písmená (len pre -e)\r\n"
"  -e - spracovať zadaný text ako regulárny výraz\r\n"
" -s - use Substitution Filters"

#: Strings.rc:125
#, c-format
msgid ""
"Apply filter. \r\n"
"Usage: ExecFilterCommand COMMAND\r\n"
" COMMAND - command to execute. %1 = filename."
msgstr ""
"Príkaz použiť filter\r\n"
"Použitie: ExecFilterCommand COMMAND\r\n"
"  COMMAND - príkaz na vykonanie. %1 v príkaze sa nahradí názvom súboru."

#: Strings.rc:127
msgid ""
"Tokenize. \r\n"
"Usage: Tokenize PATTERNS\r\n"
" PATTERNS - regex (e.g. [^\\w]+)"
msgstr ""
"Výber tokenov\r\n"
"Použitie: Tokenize (PATTERNS)\r\n"
"  PATTERNS - regulárny výraz na tokenizáciu. (napr. [^\\w]+)"

#. IDS_PLUGIN_DESCRIPTION12
#: Strings.rc:128
msgid "Trim spaces"
msgstr "Priestory orezu"

#: Strings.rc:130
msgid ""
"Select columns.\r\n"
"Usage: SelectColumns RANGES\r\n"
" or: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" RANGES - column ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -g - enable global flag\r\n"
" -e - use PATTERNS"
msgstr ""
"Vyberte niektoré stĺpce.\r\n"
"Použitie: SelectColumns RANGES\r\n"
"   alebo: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
"  RANGES - zoznam rozsahov stĺpcov na výber. (napr. -3,5-10,30-)\r\n"
"  PATTERNS - regulárny výraz\r\n"
"  -v - výber nezhodujúcich sa stĺpcov\r\n"
"  -i - ignorovať veľkosť písmen\r\n"
"  -g - zapnúť globálny príznak\r\n"
"  -e - použiť PATTERNS na porovnávanie"

#: Strings.rc:132
msgid ""
"Select lines.\r\n"
"Usage: SelectLines RANGES\r\n"
" or: SelectLines [-v] [-i] -e PATTERNS\r\n"
" RANGES - line ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -e - use PATTERNS"
msgstr ""
"Vyberte niekoľko riadkov.\r\n"
"Použitie: SelectLines RANGES\r\n"
"   alebo: SelectLines [-v] [-i] -e PATTERNS\r\n"
"  RANGES - zoznam rozsahov riadkov na výber. (napr. -3,5-10,30-)\r\n"
"  PATTERNS - regulárny výraz\r\n"
"  -v - výber nezhodujúcich sa riadkov\r\n"
"  -i - ignorovať veľkosť písmen\r\n"
"  -e - na porovnávanie použite PATTERNS"

