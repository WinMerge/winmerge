#. IDS_PLUGIN_DESCRIPTION9
#: Strings.rc:123
msgid ""
"Replace text.\r\n"
"Usage: Replace [-i] [-e] FIND REPLACE\r\n"
" or: Replace -s\r\n"
" FIND - text to find\r\n"
" REPLACE - text to replace\r\n"
" -i - ignore case (only for -e)\r\n"
" -e - regex\r\n"
" -s - use Substitution Filters"
msgstr ""
"Sostituisci il testo con un altro testo.\r\n"
"Uso sostituisci [-i] [-e] TROVA SOSTITUISCI\r\n"
" or: Replace -s\r\n"
" TROVA: testo da trovare\r\n"
" SOSTITUISCI: testo da sostituire\r\n"
" -i - ignora maiuscole e minuscole (solo per -e)\r\n"
" -e - tratta il testo specificato come un'espressione regolare\r\n"
