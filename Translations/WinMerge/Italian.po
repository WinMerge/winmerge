#. IDS_PLUGIN_DESCRIPTION9
#: Strings.rc:123
msgid ""
"Replace text.\r\n"
"Usage: Replace [-i] [-e] FIND REPLACE\r\n"
" or: Replace -s\r\n"
" FIND - text to find\r\n"
" REPLACE - text to replace\r\n"
" -i - ignore case (only for -e)\r\n"
" -e - regex\r\n"
" -s - use Substitution Filters"
msgstr ""
"Sostituisci il testo con un altro testo.\r\n"
"Uso sostituisci [-i] [-e] TROVA SOSTITUISCI\r\n"
" or: Replace -s\r\n"
" TROVA: testo da trovare\r\n"
" SOSTITUISCI: testo da sostituire\r\n"
" -i - ignora maiuscole e minuscole (solo per -e)\r\n"
" -e - tratta il testo specificato come un'espressione regolare\r\n"
" -s - use Substitution Filters"

#: Strings.rc:125
#, c-format
msgid ""
"Apply filter. \r\n"
"Usage: ExecFilterCommand COMMAND\r\n"
" COMMAND - command to execute. %1 = filename."
msgstr ""
"Applica il comando filtro.\r\n"
"Uso: ExecFilterCommand COMANDO\n"
"  COMANDO - comando da eseguire. %1 nel comando viene sostituito con il nome "
"file."

#: Strings.rc:127
msgid ""
"Tokenize. \r\n"
"Usage: Tokenize PATTERNS\r\n"
" PATTERNS - regex (e.g. [^\\w]+)"
msgstr ""
"Selezione tokenizzata.\r\n"
"Uso: tokenize PATTERNS\r\n"
"  PATTERNS: espressione regolare per la tokenizzazione. (ad es. [^\\w]+)"

#. IDS_PLUGIN_DESCRIPTION12
#: Strings.rc:128
msgid "Trim spaces"
msgstr "Ritaglia spazi"

#: Strings.rc:130
msgid ""
"Select columns.\r\n"
"Usage: SelectColumns RANGES\r\n"
" or: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" RANGES - column ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -g - enable global flag\r\n"
" -e - use PATTERNS"
msgstr ""
"Seleziona alcune colonne.\r\n"
"Uso: SelectColumns INTERVALLI\r\n"
"   o: SelectColumns [-v] [-i] [-g] -e PATTERN\r\n"
"  INTERVALL: elenco degli intervalli colonne da selezionare. (es. "
"-3,5-10,30-)\r\n"
"  PATTERN - espressione regolare\r\n"
"  -v - seleziona le colonne non corrispondenti\r\n"
"  -i - ignora maiuscole e minuscole\r\n"
"  -g - abilita flag globale\r\n"
"  -e - per la corrispondenza usa i PATTERN"

#: Strings.rc:132
msgid ""
"Select lines.\r\n"
"Usage: SelectLines RANGES\r\n"
" or: SelectLines [-v] [-i] -e PATTERNS\r\n"
" RANGES - line ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -e - use PATTERNS"
msgstr ""
"Seleziona alcune righe.\r\n"
"Uso: SelectLines INTERVALLI\r\n"
"   o: SelectLines [-v] [-i] -e PATTERN\r\n"
"  INTERVALLI - elenco intervalli linee da selezionare. (es. -3,5-10,30-)\r\n"
"  PATTERN - espressione regolare\r\n"
"  -v - seleziona le righe non corrispondenti\r\n"
"  -i - ignora maiuscole e minuscole\r\n"
"  -e - per la corrispondenza usa i PATTERN"

