#: Strings.rc:123
msgid "Replace text.\r\nUsage: Replace [-i] [-e] FIND REPLACE\r\n or: Replace -s\r\n FIND - text to find\r\n REPLACE - text to replace\r\n -i - ignore case (only for -e)\r\n -e - regex\r\n -s - use Substitution Filters"
msgstr "Zastąp tekst innym tekstem.\r\nUżycie: Replace [-i] [-e] ZNAJDŹ ZASTĄP\r\n lub: Replace -s\r\n ZNAJDŹ - tekst do znalezienia\r\n ZASTĄP - tekst do zastąpienia\r\n -i - ignoruj wielkość liter (tylko dla -e)\r\n -e - traktuj określony tekst jako wyrażenie regularne\r\n -s - użyj filtrów zamiany"

#: Strings.rc:125
#, c-format
msgid "Apply filter. \r\nUsage: ExecFilterCommand COMMAND\r\n COMMAND - command to execute. %1 = filename."
msgstr "Zastosuj filtrowanie. \r\nUżycie: ExecFilterCommand POLECENIE\r\n POLECENIE - polecenie do wykonania. %1 = nazwa pliku."

#: Strings.rc:127
