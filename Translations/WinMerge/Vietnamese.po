#. IDS_PLUGIN_DESCRIPTION9
#: Strings.rc:123
msgid ""
"Replace text.\r\n"
"Usage: Replace [-i] [-e] FIND REPLACE\r\n"
" or: Replace -s\r\n"
" FIND - text to find\r\n"
" REPLACE - text to replace\r\n"
" -i - ignore case (only for -e)\r\n"
" -e - regex\r\n"
" -s - use Substitution Filters"
msgstr ""
"Thay thế văn bản.\r\n"
"Cách dùng: Replace [-i] [-e] TÌM THAY_THẾ\r\n"
" hoặc: Replace -s\r\n"
" TÌM - văn bản cần tìm\r\n"
" THAY_THẾ - văn bản thay thế\r\n"
" -i - bỏ qua hoa thường (chỉ cho -e)\r\n"
" -e - biểu thức chính quy\r\n"
" -s - dùng Bộ lọc Thay thế"

#: Strings.rc:125
#, c-format
msgid ""
"Apply filter. \r\n"
"Usage: ExecFilterCommand COMMAND\r\n"
" COMMAND - command to execute. %1 = filename."
msgstr ""
"Áp dụng bộ lọc. \r\n"
"Cách dùng: ExecFilterCommand LỆNH\r\n"
" LỆNH - lệnh cần thực thi. %1 = tên tệp."

#: Strings.rc:127
msgid ""
"Tokenize. \r\n"
"Usage: Tokenize PATTERNS\r\n"
" PATTERNS - regex (e.g. [^\\w]+)"
msgstr ""
"Từ tố hoá. \n"
"Cách dùng: Tokenize MẪU\n"
" MẪU - biểu thức chính quy (ví dụ: [^\\w]+)"

#. IDS_PLUGIN_DESCRIPTION12
#: Strings.rc:128
msgid "Trim spaces"
msgstr "Xén bớt khoảng trắng"

#: Strings.rc:130
msgid ""
"Select columns.\r\n"
"Usage: SelectColumns RANGES\r\n"
" or: SelectColumns [-v] [-i] [-g] -e PATTERNS\r\n"
" RANGES - column ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -g - enable global flag\r\n"
" -e - use PATTERNS"
msgstr ""
"Chọn cột.\r\n"
"Cách dùng: SelectColumns KHOẢNG\r\n"
" hoặc: SelectColumns [-v] [-i] [-g] -e MẪU\r\n"
" KHOẢNG - các khoảng cột (-3,5-10,30-)\r\n"
" MẪU - biểu thức chính quy\r\n"
" -v - chọn những phần không khớp\r\n"
" -i - bỏ qua hoa thường\r\n"
" -g - bật cờ toàn cục\r\n"
" -e - dùng MẪU"

#: Strings.rc:132
msgid ""
"Select lines.\r\n"
"Usage: SelectLines RANGES\r\n"
" or: SelectLines [-v] [-i] -e PATTERNS\r\n"
" RANGES - line ranges (-3,5-10,30-)\r\n"
" PATTERNS - regex\r\n"
" -v - select non-matching\r\n"
" -i - ignore case\r\n"
" -e - use PATTERNS"
msgstr ""
"Chọn dòng.\r\n"
"Cách dùng: SelectLines KHOẢNG\r\n"
" hoặc: SelectLines [-v] [-i] -e MẪU\r\n"
