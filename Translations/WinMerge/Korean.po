"# # $1, $2와 같은 역참조가 지원됩니다\r\n"
"\r\n"
"(\\d{4})-(\\d{2})-(\\d{2})\t$1_$2_$3\r\n"

#. IDS_STRING_REPLACE_LIST_TEMPLATE
#: Merge.rc:5447
msgid ""
"# Replacement list\r\n"
"# Format: search<TAB>replacement\r\n"
"# Lines starting with # are ignored\r\n"
"\r\n"
