#. IDS_REGEX_REPLACE_LIST_TEMPLATE
#: Merge.rc:5446
msgid ""
"# Regex replacement list\r\n"
"# Format: regex<TAB>replacement\r\n"
"# Backreferences like $1, $2 are supported\r\n"
