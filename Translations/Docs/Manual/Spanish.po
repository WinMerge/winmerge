#: English/Plugins.xml:2703
msgid ""
"<filename>IgnoreLeadingLineNumbers<placeholder type=\"indexterm\" id=\"0\"/"
"></filename>"
msgstr ""
"<filename>IgnoreLeadingLineNumbers<placeholder type=\"indexterm\" id=\"0\"/"
"></filename>"

#. type: Content of: <article><section><section><para>
#: English/Plugins.xml:2707
msgid ""
"This plugin ignores the leading line numbers in text files (for example, NC "
"and BASIC files)."
msgstr ""
"Este complemento ignora los números de línea iniciales en los archivos de "
"texto (por ejemplo, archivos NC y BASIC)."

