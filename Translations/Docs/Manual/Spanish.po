#. type: Content of: <article><section><section><title><indexterm><primary>
#: English/Compare_dirs.xml:443 English/Compare_files.xml:1138
msgid "navigation functions"
msgstr "funciones de exploración"

#. type: Content of: <article><section><section><indexterm><secondary>
#: English/Compare_dirs.xml:445
msgid "folder compare"
msgstr "comparación de carpetas"

#. type: Content of: <article><section><section><orderedlist><listitem><para><inlinemediaobject>
#: English/Compare_dirs.xml:452 English/Compare_files.xml:1207
#: English/Intro_diffs.xml:225 English/Intro_diffs.xml:344
