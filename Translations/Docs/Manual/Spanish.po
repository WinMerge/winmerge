#: English/Plugins.xml:2519
msgid ""
"<filename>IgnoreColumns<placeholder type=\"indexterm\" id=\"0\"/></filename>"
msgstr ""
"<filename>IgnoreColumns<placeholder type=\"indexterm\" id=\"0\"/></filename>"

#. type: Content of: <article><section><section><para>
#: English/Plugins.xml:2523
msgid ""
"This plugin ignores characters at specified columns. The first column is "
"number 1."
msgstr ""
"Este complemento ignora los caracteres de las columnas especificadas.  La "
"primera columna es la número 1."

#. type: Content of: <article><section><section><para>
#: English/Plugins.xml:2526
msgid ""
"Note that this plugin does not support files with tabs: the plugin does not "
"fail, but all tabs are be treated as normal characters."
msgstr ""
"Tenga en cuenta que este complemento no admite archivos con tabulaciones: el "
"complemento no da error, pero todas las tabulaciones se tratan como "
"caracteres normales."

#. type: Content of: <article><section><section><para>
#: English/Plugins.xml:2529
msgid ""
"To specify columns, use plugin settings dialog or rename the <filename>dll</"
"filename> using following fields as parameters:"
msgstr ""
"Para especificar las columnas, utilice el cuadro de diálogo de configuración "
"del complemento o cambie el nombre del archivo <filename>dll</filename> "
"utilizando los siguientes campos como parámetros:"

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2534
msgid "Delimiters between ranges: _ or ,"
msgstr "Delimitadores entre rangos: _ o ,"

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2538
msgid "Delimiters between min and max: <emphasis>anything else</emphasis>"
msgstr ""
"Delimitadores entre el mínimo y el máximo: <emphasis>cualquier otro "
"carácter</emphasis>"

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2543
msgid "Min and max are included."
msgstr "Se incluyen los valores mínimo y máximo."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2547
msgid "When max = min, max can be omitted."
msgstr "Cuando máx = mín, se puede omitir máx."

#. type: Content of: <article><section><section><example><title>
#: English/Plugins.xml:2552
msgid "<filename>IgnoreColumns</filename> examples"
msgstr "<filename>IgnoreColumns</filename> ejemplos"

#. type: Content of: <article><section><section><example><variablelist><varlistentry><term>
#: English/Plugins.xml:2556
msgid "<filename>IgnoreColumns _ 3 _ 10 - 20 _ 32 - 33.dll</filename>"
msgstr "<filename>IgnoreColumns _ 3 _ 10 - 20 _ 32 - 33.dll</filename>"

#. type: Content of: <article><section><section><example><variablelist><varlistentry><listitem><simpara>
#: English/Plugins.xml:2560
msgid ""
"Ignore all characters at column 3, and in columns 10 to 20, and 32 to 33."
msgstr ""
"Ignora todos los caracteres de la columna 3, así como de las columnas 10 a "
"20 y de la 32 a la 33."

#. type: Content of: <article><section><section><example><variablelist><varlistentry><term>
#: English/Plugins.xml:2566
msgid "<filename>IgnoreColumns_1,30 to 40.dll</filename>"
msgstr "<filename>IgnoreColumns_1,30 to 40.dll</filename>"

#. type: Content of: <article><section><section><example><variablelist><varlistentry><listitem><simpara>
#: English/Plugins.xml:2569
msgid "Ignore all the characters in column 1, and in columns 30 to 40."
msgstr "Ignora todos los caracteres de la columna 1 y de las columnas 30 a 40."

