#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1268
msgid "<literal>Size &lt; 10KB</literal> - Any side's size is less than 10KB"
msgstr ""
"<literal>Size &lt; 10KB</literal> - El tamaño de cualquier archivo es "
"inferior a 10 KB"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1269
msgid ""
"<literal>LeftSize &gt;= 10MB</literal> - Left side file is at least 10MB"
msgstr ""
"<literal>LeftSize &gt;= 10MB</literal> - El archivo izquierdo ocupa al menos "
"10 MB"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1270
msgid "<literal>allof(Size &lt; 1MB)</literal> - All sides are under 1MB"
msgstr ""
"<literal>allof(Size &lt; 1MB)</literal> - Todos los lados tienen menos de 1 "
"MB"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1271
msgid ""
"<literal>abs(LeftSize - RightSize) &lt; 1KB</literal> - Size difference is "
"small"
msgstr ""
"<literal>abs(LeftSize - RightSize) &lt; 1KB</literal> - La diferencia de "
"tamaño es mínima"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1272
msgid ""
"<literal>DateStr = \"2025-07-20\"</literal> - File was last modified on that "
"date"
msgstr ""
"<literal>DateStr = \"2025-07-20\"</literal> - El archivo se modificó por "
"última vez en esa fecha"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1273
msgid "<literal>Date &gt;= today()</literal> - Modified today or later"
msgstr "<literal>Date &gt;= today()</literal> - Modificado hoy o más adelante"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1274
msgid ""
"<literal>isWithin(Date, today() - 7days, today())</literal> - File modified "
"within the last week"
msgstr ""
"<literal>isWithin(Date, today() - 7days, today())</literal> - Archivo "
"modificado en la última semana"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1275
msgid ""
"<literal>inRange(Size, 1KB, 10MB)</literal> - File size is between 1KB "
"(inclusive) and 10MB (exclusive)"
msgstr ""
"<literal>inRange(Size, 1KB, 10MB)</literal> - El tamaño del archivo debe "
"estar comprendido entre 1 KB (incluido) y 10 MB (no incluido)"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1276
msgid ""
"<literal>allof(isWithin(Size, 100KB, 1MB))</literal> - All file sizes are "
"between 100KB and 1MB"
msgstr ""
"<literal>allof(isWithin(Size, 100KB, 1MB))</literal> - Todos los archivos "
"tienen un tamaño comprendido entre 100 KB y 1 MB"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1277
msgid "<literal>AttrStr contains \"R\"</literal> - File is read-only"
msgstr ""
"<literal>AttrStr contains \"R\"</literal> - El archivo es de solo lectura"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1278
msgid "<literal>Name matches \"file[0-9]\\.txt\"</literal> - Regex on filename"
msgstr ""
"<literal>Name matches \"file[0-9]\\.txt\"</literal> - Expresión regular en "
"el nombre del archivo"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1279
msgid ""
"<literal>Content contains \"Test\"</literal> - File content includes keyword"
msgstr ""
"<literal>Content contains \"Test\"</literal> - El contenido del archivo "
"incluye la palabra clave"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1280
msgid ""
"<literal>sublines(Content, 0, 1) contains \"XML\"</literal> - First line "
"contains \"XML\""
msgstr ""
"<literal>sublines(Content, 0, 1) contains \"XML\"</literal> - La primera "
"línea contiene \"XML\""

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1281
msgid ""
"<literal>(Extension = \"log\" and Size > 10MB) or (Date &lt; today() - "
"7days)</literal> - Large log files or files older than a week"
msgstr ""
"<literal>(Extension = \"log\" and Size > 10MB) or (Date &lt; today() - "
"7days)</literal> - Archivos de registro de gran tamaño o archivos con más de "
"una semana de antigüedad"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1282
msgid ""
"<literal>AttrStr not contains \"H\" and Name like \"*.tmp\"</literal> - Non-"
"hidden temporary files"
msgstr ""
"<literal>AttrStr not contains \"H\" and Name like \"*.tmp\"</literal> - "
"Archivos temporales no ocultos"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1283
msgid ""
"<literal>isWithin(Extension, \"a\", \"m\") and inRange(Size, 0, 1MB)</"
"literal> - Files with extensions from 'a' to 'm' and size less than 1MB"
msgstr ""
"<literal>isWithin(Extension, \"a\", \"m\") and inRange(Size, 0, 1MB)</"
"literal> - Archivos con extensiones de la 'a' a la 'm' y un tamaño inferior "
"a 1 MB"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1284
msgid ""
"<literal>toLower(Name) = \"readme.txt\"</literal> - Case-insensitive "
"filename matching"
msgstr ""
"<literal>toLower(Name) = \"readme.txt\"</literal> - Coincidencia de nombres "
"de archivo sin distinción entre mayúsculas y minúsculas"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1285
msgid ""
"<literal>toHalfWidth(Name) like \"*.txt\"</literal> - Match after converting "
"full-width to half-width"
msgstr ""
"<literal>toHalfWidth(Name) like \"*.txt\"</literal> - Coincidir tras "
"convertir los caracteres de ancho completo a caracteres de ancho medio"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1286
msgid ""
"<literal>Different</literal> - Show only files/folders that are different "
"(Display filter only)"
msgstr ""
"<literal>Different</literal> - Mostrar solo los archivos y carpetas que han "
"cambiado (solo filtro de visualización)"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1287
msgid ""
"<literal>Identical</literal> - Show only files/folders that are identical "
"(Display filter only)"
msgstr ""
"<literal>Identical</literal> - Mostrar solo los archivos y carpetas que sean "
"idénticos (solo filtro de visualización)"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1288
msgid ""
"<literal>allof(Binary)</literal> - Show only files that are binary on all "
"sides (Display filter only)"
msgstr ""
"<literal>allof(Binary)</literal> - Mostrar solo los archivos que sean "
"binarios en todos los lados (solo filtro de visualización)"

#. type: Content of: <article><section><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1289
msgid ""
"<literal>DifferentLeftMiddle and not DifferentMiddleRight</literal> - In 3-"
"way comparison, show files where only left-middle pair differs (Display "
"filter only)"
msgstr ""
"<literal>DifferentLeftMiddle and not DifferentMiddleRight</literal> - En una "
"comparación a tres bandas, mostrar los archivos en los que solo difiere el "
"par izquierdo-central (solo filtro de visualización)"

#. type: Content of: <article><section><title>
#: English/Filters.xml:1296
msgid ""
"Using file filters<placeholder type=\"indexterm\" id=\"0\"/><placeholder "
"type=\"indexterm\" id=\"1\"/>"
msgstr ""
"Uso de filtros de archivos<placeholder type=\"indexterm\" id=\"0\"/"
"><placeholder type=\"indexterm\" id=\"1\"/>"

#. type: Content of: <article><section><para>
#: English/Filters.xml:1306
msgid ""
"<glossterm>File filters</glossterm> are text files with an extension of "
"<filename>flt</filename>. They enable you to apply multiple filtering rules "
"to a folder comparison. Unlike file masks, file filters can either include "
"or exclude matches."
msgstr ""
"<glossterm>Los filtros de archivos</glossterm> son archivos de texto con la "
"extensión <filename>flt</filename>. Permiten aplicar varias reglas de "
"filtrado a una comparación de carpetas. A diferencia de las máscaras de "
"archivos, los filtros de archivos pueden incluir o excluir coincidencias."

#. type: Content of: <article><section><para><indexterm><secondary>
#: English/Filters.xml:1314
msgid "template"
msgstr "plantilla"

#. type: Content of: <article><section><para>
#: English/Filters.xml:1311
msgid ""
"<placeholder type=\"indexterm\" id=\"0\"/>WinMerge installs a number of "
"predefined file filters. If these file filters do not provide the filtering "
"you need, you can create your own. To make that task easier, WinMerge also "
"provides a template file named <filename>FileFilter.tmpl</filename>. This "
"section describes how to apply file filters to comparisons, and documents "
"the file filter syntax.  <xref linkend=\"Filters_dlg\" /> describes how to "
"add, edit, and manage filters."
msgstr ""
"<placeholder type=\"indexterm\" id=\"0\"/>WinMerge incluye varios filtros de "
"archivos predefinidos. Si estos filtros no le ofrecen las opciones que "
"necesita, puede crear los suyos propios.  Para facilitar esa tarea, WinMerge "
"también incluye un archivo de plantilla llamado <filename>FileFilter.tmpl</"
"filename>. En esta sección se describe cómo aplicar filtros de archivos a "
"las comparaciones y se detalla la sintaxis de los filtros de archivos. En "
"<xref linkend=\"Filters_dlg\" /> se explica cómo añadir, editar y gestionar "
"filtros."

#. type: Content of: <article><section><section><title><indexterm><secondary>
#: English/Filters.xml:1327 English/Filters.xml:1331
msgid "locations"
msgstr "ubicaciones"

#. type: Content of: <article><section><section><title>
#: English/Filters.xml:1324
msgid ""
"File filter locations<placeholder type=\"indexterm\" id=\"0\"/><placeholder "
"type=\"indexterm\" id=\"1\"/>"
msgstr ""
"Ubicaciones de los filtros de archivos<placeholder type=\"indexterm\" "
"id=\"0\"/><placeholder type=\"indexterm\" id=\"1\"/>"

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1334
msgid "WinMerge automatically detects file filters in these locations:"
msgstr ""
"WinMerge detecta automáticamente los filtros de archivos en estas "
"ubicaciones:"

#. type: Content of: <article><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:1339
msgid "Filters subfolder in the WinMerge installation folder"
msgstr "Subcarpeta de filtros en la carpeta de instalación de WinMerge"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1342
msgid ""
"This is where the predefined file filters are installed. For example, "
"<filename>C:\\Program Files\\WinMerge\\Filters</filename>. You can create or "
"copy filter files in this location to make them available to all users on "
"your system."
msgstr ""
"Aquí es donde se instalan los filtros de archivos predefinidos. Por ejemplo, "
"<filename>C:\\Program Files\\WinMerge\\Filters</filename>.  Puede crear o "
"copiar filtros de archivos en esta ubicación para que estén disponibles para "
"todos los usuarios del sistema."

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1347
msgid ""
"Before creating a new file filter, see if the predefined ones already "
"contain what you need. If not, you might find useful rule examples in the "
"existing files."
msgstr ""
"Antes de crear un nuevo filtro de archivos, compruebe si los predefinidos ya "
"contienen lo que necesita. Si no es así, es posible que encuentre ejemplos "
"de reglas útiles en los archivos existentes."

#. type: Content of: <article><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:1354
msgid "Default private filter folder"
msgstr "Carpeta de filtros privada predeterminada"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1357
msgid ""
"The location of this folder is defined in the System page of WinMerge "
"options. By default, it is specified as a subfolder in your user profile "
"folder (for example, <filename>Documents</filename> in Windows 10). Filters "
"that are created or copied here are normally visible only to you. If you "
"create new file filters, you can copy them here to keep them private."
msgstr ""
"La ubicación de esta carpeta se define en la página \"Sistema\" de las "
"opciones de WinMerge. De forma predeterminada, se especifica como una "
"subcarpeta dentro de la carpeta de su perfil de usuario (por ejemplo, "
"<filename>Documentos</filename> en Windows 10). Los filtros que se crean o "
"se copian aquí normalmente solo son visibles para usted. Si crea nuevos "
"filtros de archivos, puede copiarlos aquí para mantenerlos privados."

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1367
msgid ""
"Before you can apply file filters that exist in any other folder, you must "
"first install them."
msgstr ""
"Antes de poder aplicar los filtros de archivos que se encuentran en "
"cualquier otra carpeta, debe instalarlos primero."

#. type: Content of: <article><section><section><title><indexterm><secondary>
#: English/Filters.xml:1375
msgid "applying"
msgstr "aplicación"

#. type: Content of: <article><section><section><title>
#: English/Filters.xml:1372
msgid "Applying file filters<placeholder type=\"indexterm\" id=\"0\"/>"
msgstr ""
"Aplicación de filtros de archivos<placeholder type=\"indexterm\" id=\"0\"/>"

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1378
msgid "You can apply a file filter using any of these methods:"
msgstr ""
"Puede aplicar un filtro de archivos mediante cualesquiera de estos métodos:"

#. type: Content of: <article><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1382
msgid ""
"When you launch a folder compare from the Select Files or Folders dialog:"
msgstr ""
"Cuando inicie una comparación de carpetas desde el cuadro de diálogo "
"\"Seleccione archivos o carpetas\":"

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1387
msgid ""
"After choosing the <guilabel>1st</guilabel> and <guilabel>2nd</guilabel> "
"folders, click <guibutton>Select</guibutton> next to the <guilabel>Filter</"
"guilabel> field."
msgstr ""
"Después de seleccionar la <guilabel>1ª</guilabel> y la <guilabel>2ª</"
"guilabel> carpeta, haga clic en <guibutton>Seleccionar</guibutton> junto al "
"campo <guilabel>Filtro</guilabel>."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1394
msgid ""
"In the Filters dialog, use the File Filters tab to choose a file filter and "
"load it in the <guilabel>Filter</guilabel> field."
msgstr ""
"En el cuadro de diálogo \"Filtros\", utilice la pestaña \"Filtros de "
"archivos\" para seleccionar un filtro de archivos y cargarlo en el campo "
"<guilabel>Filtros</guilabel>."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><note><para>
#: English/Filters.xml:1399
msgid ""
"If a file filter is currently enabled, the selected file filter is already "
"loaded in the <guilabel>Filter</guilabel> field."
msgstr ""
"Si hay algún filtro de archivos activado, el filtro seleccionado ya aparece "
"en el campo <guilabel>Filtro</guilabel>."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1407
msgid ""
"Proceed with the compare operation. The file in the <guilabel>Filter</"
"guilabel> field is applied when you start the operation."
msgstr ""
"Continúe con la operación de comparación. El archivo indicado en el campo "
"<guilabel>Filtro</guilabel> se aplica al iniciar la operación."

#. type: Content of: <article><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1415
msgid ""
"To change file filtering after you have already launched a folder compare "
"operation (for example, applying a different filter or disabling filtering):"
msgstr ""
"Para modificar el filtrado de archivos una vez iniciada una operación de "
"comparación de carpetas (por ejemplo, para aplicar un filtro diferente o "
"desactivar el filtrado):"

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1421 English/Filters.xml:1689
msgid ""
"Click <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Filters</"
"guimenuitem> </menuchoice>."
msgstr ""
"Haga clic en <menuchoice> <guimenu>Herraminetas</guimenu> "
"<guimenuitem>Filtros</guimenuitem> </menuchoice>."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1429
msgid ""
"In the Filters dialog, configure your new file filter setting, and click "
"<guibutton>OK</guibutton>."
msgstr ""
"En el cuadro de diálogo \"Filtros\" configure los nuevos ajustes del filtro "
"de archivos y haga clic en «Aceptar».<guibutton>Aceptar</guibutton>."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1434
msgid ""
"The new filtering is not automatically applied when you close the Filters "
"dialog: press <keycap>F5</keycap> to see the new results in the Folder "
"Compare window."
msgstr ""
"El nuevo filtro no se aplica automáticamente al cerrar el cuadro de diálogo "
"\"Filtros\": pulse <keycap>F5</keycap> para ver los nuevos resultados en la "
"ventana de comparación de carpetas."

#. type: Content of: <article><section><section><itemizedlist><listitem><para><indexterm><secondary>
#: English/Filters.xml:1445
msgid "applying file filters"
msgstr "aplicar filtros de archivos"

#. type: Content of: <article><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1442
msgid ""
"<placeholder type=\"indexterm\" id=\"0\"/>When you launch a folder compare "
"from the WinMerge command line, use the <option>-f</option> flag to specify "
"a file filter."
msgstr ""
"<placeholder type=\"indexterm\" id=\"0\"/>Cuando inicie una comparación de "
"carpetas desde la línea de comandos de WinMerge, utilice el parámetro "
"<option>-f</option> para especificar un filtro de archivos."

#. type: Content of: <article><section><section><title><indexterm><secondary>
#: English/Filters.xml:1457
msgid "file filter"
msgstr "filtro de archivos"

#. type: Content of: <article><section><section><title><indexterm><secondary>
#: English/Filters.xml:1461
msgid "syntax"
msgstr "sintaxis"

#. type: Content of: <article><section><section><title>
#: English/Filters.xml:1454
msgid ""
"File filter syntax<placeholder type=\"indexterm\" id=\"0\"/><placeholder "
"type=\"indexterm\" id=\"1\"/>"
msgstr ""
"Sintaxis del filtro de archivos<placeholder type=\"indexterm\" id=\"0\"/"
"><placeholder type=\"indexterm\" id=\"1\"/>"

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1464
msgid ""
"This section describes the syntax of WinMerge file filters and provides "
"guidelines for writing them."
msgstr ""
"En esta sección se describe la sintaxis de los filtros de archivos de "
"WinMerge y se ofrecen pautas para su creación."

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1467
msgid ""
"The comment delimiter is <code>##</code>. After a comment delimiter, all "
"characters in a line are ignored. WinMerge ignores most whitespace "
"characters in rules. However, a comment must always be preceded by one or "
"more whitespace (space or tab) characters. To use <code>##</code> as "
"characters in a rule, omit the whitespace prefix."
msgstr ""
"El delimitador de comentarios es <code>##</code>. Después de un delimitador "
"de comentarios, se ignoran todos los caracteres de la línea. WinMerge ignora "
"la mayoría de los caracteres de espacio en blanco en las reglas. Sin "
"embargo, un comentario siempre debe ir precedido de uno o varios caracteres "
"de espacio en blanco (espacio o tabulación).  Para utilizar <code>##</code> "
"como caracteres en una regla, omita el prefijo de espacio en blanco."

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1473
msgid "The first two required lines of a file filter are:"
msgstr "Las dos primeras líneas obligatorias de un filtro de archivo son:"

#. type: Content of: <article><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:1477
msgid "name"
msgstr "nombre"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1480
msgid "The filter name that is listed in the Files dialog"
msgstr "El nombre del filtro que aparece en el cuadro de diálogo \"Archivo\""

#. type: Content of: <article><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:1485
msgid "def"
msgstr "def"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1488
msgid "The type of filtering to be applied. Specify one of these values:"
msgstr ""
"El tipo de filtrado que se va a aplicar. Especifique uno de estos valores:"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><variablelist><varlistentry><term>
#: English/Filters.xml:1493
msgid "include"
msgstr "include"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1496
msgid "Includes everything except items matching the specified rule."
msgstr "Incluye todo excepto los elementos que cumplan la regla especificada."

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><variablelist><varlistentry><term>
#: English/Filters.xml:1502
msgid "exclude"
msgstr "exclude"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1505
msgid "Excludes everything except items matching the specified rule."
msgstr "Excluye todo excepto los elementos que cumplan la regla especificada."

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1508
msgid ""
"When you choose the exclude method, you must also add a <guilabel>d</"
"guilabel> (directory) rule that specifies the subfolders. It's usually a "
"good idea to specify all subfolders, like this:"
msgstr ""
"Cuando elija el método de exclusión, también debe añadir una regla "
"<guilabel>d</guilabel> (directorio) que especifique las subcarpetas.  Por lo "
"general, es recomendable especificar todas las subcarpetas de esta manera:"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><variablelist><varlistentry><listitem><screen>
#: English/Filters.xml:1513
#, no-wrap
msgid "d: \\\\*$ ## Subfolders"
msgstr "d: \\\\*$ ## Subfolders"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><tip><para>
#: English/Filters.xml:1519
msgid ""
"Don't confuse these terms. Remember, in file filters, an <guilabel>include</"
"guilabel> rule does not specify what to include, it specifies what "
"<emphasis>not</emphasis> to include.  Similarly, <guilabel>exclude</"
"guilabel> does not specify what to exclude, it specifies what not to exclude."
msgstr ""
"No confunda estos términos. Recuerde que, en los filtros de archivos, una "
"regla <guilabel>include</guilabel> no especifica qué se debe incluir, sino "
"qué <emphasis>no</emphasis> se debe incluir. Del mismo modo, una regla "
"<guilabel>exclude</guilabel> no especifica qué se debe excluir, sino qué no "
"se debe excluir."

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1529
msgid ""
"Next, your file should contain one or more filter rules. You can add as many "
"rules as you like. There must be one rule per line, and each rule must be "
"entirely on one line (no line breaks are allowed in a rule).  A rule begins "
"with a type designator, followed by either a regular expression or a filter "
"expression.  The supported type designators are:"
msgstr ""
"A continuación, el archivo debe contener una o varias reglas de filtrado. "
"Puede añadir tantas reglas como desee. Debe haber una regla por línea y cada "
"regla debe estar completa en una sola línea (no se permiten saltos de línea "
"dentro de una regla).  Una regla comienza con un designador de tipo, seguido "
"de una expresión regular o de una expresión de filtrado. Los designadores de "
"tipo admitidos son:"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1537
msgid "Match file names using regular expressions"
msgstr "Comparar nombres de archivos mediante expresiones regulares"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1538
msgid "Exclude files matching regex (Available since 2.16.19)"
msgstr ""
"Excluir archivos que coincidan con la expresión regular (disponible a partir "
"de la versión 2.16.19)"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1539
msgid "Match folder names using regex"
msgstr "Buscar nombres de carpetas utilizando expresiones regulares"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1540
msgid "Exclude folders matching regex (Available since 2.16.19)"
msgstr ""
"Excluir carpetas que coincidan con la expresión regular (disponible desde la "
"versión 2.16.19)"

#. type: Content of: <article><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:1545
msgid "e: <replaceable>expr</replaceable>"
msgstr "e: <replaceable>expr</replaceable>"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1545
msgid ""
"Filter expression applied to both files and folders (e.g. e:Name like "
"\"Common*.*\") (Available since 2.16.56)"
msgstr ""
"Expresión de filtro aplicada tanto a archivos como a carpetas (ej. e:Name "
"like \"Common*.*\") (disponible desde la versión 2.16.56)"

#. type: Content of: <article><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:1546
msgid "e!: <replaceable>expr</replaceable>"
msgstr "e!: <replaceable>expr</replaceable>"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1546
msgid ""
"Filter expression to exclude both files and folders (Available since 2.16.56)"
msgstr ""
"Expresión de filtro para excluir tanto archivos como carpetas (disponible "
"desde la versión 2.16.56)"

#. type: Content of: <article><section><section><para><indexterm><secondary>
#: English/Filters.xml:1553
msgid "special characters in filters"
msgstr "caracteres especiales en los filtros"

#. type: Content of: <article><section><section><para><indexterm><secondary>
#: English/Filters.xml:1557
msgid "in file filters"
msgstr "en los filtros de archivos"

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1549
msgid ""
"Among the many regexp special characters, the following are particularly "
"important in file filter rules:<placeholder type=\"indexterm\" id=\"0\"/"
"><placeholder type=\"indexterm\" id=\"1\"/>"
msgstr ""
"Entre los numerosos caracteres especiales de las expresiones regulares, los "
"siguientes son especialmente importantes en las reglas de filtrado de "
"archivos:<placeholder type=\"indexterm\" id=\"0\"/><placeholder "
"type=\"indexterm\" id=\"1\"/>"

#. type: Content of: <article><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:1562
msgid "^ (beginning of line)"
msgstr "^ (principio de línea)"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1565
msgid "Frequently required for rules to work correctly."
msgstr "A menudo es necesario para que las reglas funcionen correctamente."

#. type: Content of: <article><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:1570
msgid "$ (end of line)"
msgstr "$ (fin de línea)"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1573
msgid "Frequently required for rules to work correctly. For example:"
msgstr ""
"A menudo es necesario para que las reglas funcionen correctamente.  Por "
"ejemplo:"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><screen>
#: English/Filters.xml:1576
#, no-wrap
msgid ""
"\\.c$ ## matches only file names with the extension, <filename>c</filename>.\n"
"\\.c  ## matches any extension beginning with <filename>c</filename>, like <filename>cpp</filename> and <filename>com</filename>."
msgstr ""
"\\.c$ ## solo busca nombres de archivo con esa extensión, <filename>c</filename>.\n"
"\\.c  ## coincide con cualquier extensión que empiece por <filename>c</filename>, como <filename>cpp</filename> y <filename>com</filename>."

#. type: Content of: <article><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:1582
msgid "\\ (escape)"
msgstr "\\ (escape)"

#. type: Content of: <article><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1585
msgid ""
"Forces special characters to match normal characters. For example, to match "
"a folder name, precede the folder backslash delimiter with a backslash "
"(<code>\\\\</code>). To match the dot in a file name, specify a backslash "
"followed by a dot (<code>\\.</code>)."
msgstr ""
"Obliga a que los caracteres especiales se traten como caracteres normales.  "
"Por ejemplo, para que coincida el nombre de una carpeta, antepone una barra "
"invertida doble (<code>\\\\</code>) al delimitador de la carpeta. Para que "
"coincida el punto de un nombre de archivo, especifica una barra invertida "
"seguida de un punto (<code>\\.</code>)."

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1594
msgid ""
"No special characters or wildcards are used to match file names. To match "
"all filenames of a certain type, simply omit the filename."
msgstr ""
"No se utilizan caracteres especiales ni comodines para buscar nombres de "
"archivo. Para buscar todos los nombres de archivo de un tipo determinado, "
"basta con omitir el nombre del archivo."

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1597
msgid ""
"Rules are case-insensitive. For example, <code>f: \\.bat$</code> matches "
"<filename>winmerge.bat</filename> and <filename>compare.BAT</filename>."
msgstr ""
"Las reglas no distinguen entre mayúsculas y minúsculas. Por ejemplo, "
"<code>f: \\.bat$</code> coincide con <filename>winmerge.bat</filename> y "
"<filename>compare.BAT</filename>."

#. type: Content of: <article><section><section><example><title>
#: English/Filters.xml:1602
msgid "File filter rule examples"
msgstr "Ejemplos de reglas de filtrado de archivos"

#. type: Content of: <article><section><section><example><para>
#: English/Filters.xml:1604
msgid "Some simple file filter rules:"
msgstr "Algunas reglas sencillas de filtrado de archivos:"

#. type: Content of: <article><section><section><example><screen>
#: English/Filters.xml:1606
#, no-wrap
msgid ""
"f: \\.cpp$ ## Match <filename>*.cpp</filename> files\n"
"f: \\.h$ ## Match <filename>*.h</filename> files\n"
"f: ^My ## Match <filename>My*.*</filename> files\n"
"f: Dlg\\. ## Match <filename>*Dlg.*</filename> files\n"
"d: \\\\test$ ## Match <filename>test</filename> folders\n"
"d: ^\\\\Build$ ## Match <filename>Build</filename> folders\n"
"d: Temp$ ## Match <filename>*Temp</filename> folders (for example, <filename>FirstTemp</filename>)\n"
"d: Src ## Match <filename>*Src*</filename> folders"
msgstr ""
"f: \\.cpp$ ## Coincide con archivos <filename>*.cpp</filename>\n"
"f: \\.h$ ## Coincide con archivos <filename>*.h</filename>\n"
"f: ^My ## Coincide con archivos <filename>My*.*</filename>\n"
"f: Dlg\\. ## Coincide con archivos <filename>*Dlg.*</filename>\n"
"d: \\\\test$ ## Coincide con carpetas <filename>test</filename>\n"
"d: ^\\\\Build$ ## Coincide con carpetas <filename>Build</filename>\n"
"d: Temp$ ## Coincide con carpetas <filename>*Temp</filename> (por ejemplo, <filename>FirstTemp</filename>)\n"
"d: Src ## Coincide con carpetas <filename>*Src*</filename>"

#. type: Content of: <article><section><section><example><para>
#: English/Filters.xml:1615
msgid "Some rules with more complex regular expressions:"
msgstr "Algunas reglas con expresiones regulares más complejas:"

#. type: Content of: <article><section><section><example><screen>
#: English/Filters.xml:1617
#, no-wrap
msgid ""
"f: ^\\.#.*$ ## <filename>.#filename.version</filename> files\n"
"f: Dlg\\.c(pp)?$ ## <filename>*Dlg.c</filename> and <filename>*Dlg.cpp</filename> files\n"
"f: ^I.*\\.h$ ## <filename>I*.h</filename> files\n"
"f: Srv[1-9]\\.def$ ## <filename>*Srv1.def</filename> to <filename>*Srv9.def</filename> files\n"
"f: ^[h,k,m] ## <filename>h*.*</filename>, <filename>k*.*</filename>, and <filename>m*.*</filename> files"
msgstr ""
"f: ^\\.#.*$ ## archivo <filename>.#nombre_archivo.version</filename>\n"
"f: Dlg\\.c(pp)?$ ## archivos <filename>*Dlg.c</filename> y <filename>*Dlg.cpp</filename>\n"
"f: ^I.*\\.h$ ## archivos <filename>I*.h</filename>\n"
"f: Srv[1-9]\\.def$ ## archivos <filename>*Srv1.def</filename> a <filename>*Srv9.def</filename>\n"
"f: ^[h,k,m] ## archivos <filename>h*.*</filename>, <filename>k*.*</filename> y <filename>m*.*</filename>"

#. type: Content of: <article><section><section><title><indexterm><secondary>
#: English/Filters.xml:1630 English/Filters.xml:1737
msgid "line"
msgstr "línea"

#. type: Content of: <article><section><title><indexterm><secondary>
#: English/Filters.xml:1634 English/Filters.xml:1868
msgid "in file comparisons"
msgstr "en la comparación de archivos"

#. type: Content of: <article><section><title>
#: English/Filters.xml:1627
msgid ""
"Using line filters<placeholder type=\"indexterm\" id=\"0\"/><placeholder "
"type=\"indexterm\" id=\"1\"/>"
msgstr ""
"Uso de filtros de línea<placeholder type=\"indexterm\" id=\"0\"/"
"><placeholder type=\"indexterm\" id=\"1\"/>"

#. type: Content of: <article><section><para>
#: English/Filters.xml:1637
msgid ""
"In a file comparison, you can use line filters to ignore single lines.  For "
"example, you might use line filters to ignore comments or certain type of "
"generated code, like version control system timestamps. Each line filter is "
"a rule, and you can apply any number of line filters to a file comparison."
msgstr ""
"En una comparación de archivos, puede utilizar filtros de línea para ignorar "
"líneas concretas. Por ejemplo, puede utilizar filtros de línea para ignorar "
"comentarios o determinados tipos de código generado, como las marcas de "
"tiempo de los sistemas de control de versiones. Cada filtro de línea es una "
"regla y puede aplicar tantos filtros de línea como desee a una comparación "
"de archivos."

#. type: Content of: <article><section><para>
#: English/Filters.xml:1643
msgid ""
"To learn how to add, edit, and manage filters, see <xref "
"linkend=\"Filters_dlg\" />."
msgstr ""
"Para saber cómo añadir, editar y gestionar filtros, consulte <xref "
"linkend=\"Filters_dlg\" />."

#. type: Content of: <article><section><section><title>
#: English/Filters.xml:1647
msgid "Applying line filters"
msgstr "Aplicación de filtros de línea"

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1649
msgid "You can apply line filters using any of these methods:"
msgstr ""
"Puede aplicar filtros de línea utilizando cualesquiera de estos métodos:"

#. type: Content of: <article><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1653
msgid "When you launch a file compare from the Select Files or Folders dialog"
msgstr ""
"Al iniciar una comparación de archivos desde el cuadro de diálogo "
"\"Seleccione archivos o carpetas\""

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1658
msgid ""
"After choosing the <guilabel>1st</guilabel> and <guilabel>2nd</guilabel> "
"files, click <guibutton>Select</guibutton> next to the <guilabel>Filter</"
"guilabel> field."
msgstr ""
"Después de seleccionar el <guilabel>1º</guilabel> y el <guilabel>2º</"
"guilabel> archivo, haga clic en <guibutton>Seleccionar</guibutton> junto al "
"campo <guilabel>Filtro</guilabel>."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1665
msgid ""
"In the Filters dialog, use the Line Filters tab to enable the line filters "
"you want to use (if any), or to see what line filters are currently enabled."
msgstr ""
"En el cuadro de diálogo \"Filtros\", utilice la pestaña \"Filtros de línea\" "
"para activar los filtros de línea que desee utilizar (si los hay) o para ver "
"qué filtros de línea están activados actualmente."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><note><para>
#: English/Filters.xml:1670
msgid ""
"The <guilabel>Filter</guilabel> field does not indicate what line filters "
"are enabled."
msgstr ""
"El campo <guilabel>Filtro</guilabel> no indica qué filtros de línea están "
"activados."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1677
msgid ""
"Proceed with the file compare operation. The enabled line filters are "
"applied when you start the operation."
msgstr ""
"Continúe con la operación de comparación de archivos. Los filtros de línea "
"activados se aplican al iniciar la operación."

#. type: Content of: <article><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1684
msgid ""
"After you have already launched a file compare operation (for example, to "
"apply different filters or disabling filtering)"
msgstr ""
"Una vez que haya iniciado una operación de comparación de archivos (por "
"ejemplo, para aplicar filtros diferentes o desactivar el filtrado)"

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1697
msgid "Open the File Filters tab."
msgstr "Vaya a la pestaña \"Filtros de archivos\"."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1701
msgid ""
"Check the individual line filters you want to apply, and uncheck filters "
"that you don't want to apply."
msgstr ""
"Marque los filtros de línea que desee aplicar y desmarque los que no desee "
"aplicar."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1704
msgid ""
"You can also add, edit, and remove filters from the list by using the "
"<guibutton>New</guibutton>, <guibutton>Edit</guibutton>, and "
"<guibutton>Remove</guibutton> buttons."
msgstr ""
"También puede añadir, editar y eliminar filtros de la lista mediante los "
"botones <guibutton>Nuevo</guibutton>, <guibutton>Editar</guibutton> y "
"<guibutton>Eliminar</guibutton>."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1710
msgid ""
"To turn on line filtering, check the <guilabel>Enable Line Filters</"
"guilabel>. To turn line filtering off, uncheck the option."
msgstr ""
"Para activar el filtrado de líneas, marque la casilla <guilabel>Habilitar "
"Filtros de líneas</guilabel>. Para desactivar el filtrado de líneas, "
"desmarque la casilla."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1716
msgid "Click <guibutton>OK</guibutton> to dismiss the File Filters dialog."
msgstr ""
"Haga clic en <guibutton>Aceptar</guibutton> para cerrar el cuadro de diálogo "
"\"Filtros de archivos\"."

#. type: Content of: <article><section><section><itemizedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:1721
msgid ""
"Click <keycap>F5</keycap> to apply your changes and refresh the File Compare "
"window."
msgstr ""
"Haga clic en <keycap>F5</keycap> para aplicar los cambios y actualizar la "
"ventana de comparación de archivos."

#. type: Content of: <article><section><section><title><indexterm><secondary>
#: English/Filters.xml:1733
msgid "line filter"
msgstr "filtro de línea"

#. type: Content of: <article><section><section><title><indexterm><secondary>
#: English/Filters.xml:1741
msgid "in line filters"
msgstr "en filtros de línea"

#. type: Content of: <article><section><section><title>
#: English/Filters.xml:1730
msgid ""
"Line filter syntax<placeholder type=\"indexterm\" id=\"0\"/><placeholder "
"type=\"indexterm\" id=\"1\"/><placeholder type=\"indexterm\" id=\"2\"/>"
msgstr ""
"Sintaxis del filtro de línea<placeholder type=\"indexterm\" id=\"0\"/"
"><placeholder type=\"indexterm\" id=\"1\"/><placeholder type=\"indexterm\" "
"id=\"2\"/>"

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1744
msgid ""
"A line filter is a rule that is evaluated against each single-line "
"difference in your compared files, if line filter rules are enabled. When a "
"rule matches a single-line difference, the difference is ignored."
msgstr ""
"Un filtro de línea es una regla que se aplica a cada diferencia de una sola "
"línea en los archivos comparados, siempre que las reglas de filtro de línea "
"estén activadas. Cuando una regla coincide con una diferencia de una sola "
"línea, dicha diferencia se ignora."

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1748
msgid ""
"Ignored differences are marked in the File Compare window with the "
"<guilabel>Ignored Difference</guilabel> color (as defined in the Colors page "
"of WinMerge Options). This enables you to distinguish ignored differences "
"from other types. However, you cannot select or merge ignored difference."
msgstr ""
"Las diferencias ignoradas se marcan en la ventana de comparación de archivos "
"con el color de <guilabel>Diferencia ignorada</guilabel> (tal y como se "
"define en la página \"Colores\" de las opciones de WinMerge). Esto le "
"permite distinguir las diferencias ignoradas de otros tipos. Sin embargo, no "
"puede seleccionar ni fusionar las diferencias ignoradas."

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1754
msgid "Line filter matching can be described in terms of two ideas:"
msgstr ""
"La adaptación de filtros de línea puede describirse a partir de dos "
"conceptos:"

#. type: Content of: <article><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1758
msgid ""
"When a rule matches any part of the line, the entire difference is ignored. "
"Therefore, you cannot filter just part of a line. For example, suppose two "
"files have the following single-line difference:"
msgstr ""
"Cuando una regla coincide con cualquier parte de la línea, se ignora toda la "
"diferencia. Por lo tanto, no es posible filtrar solo una parte de una línea. "
"Por ejemplo, supongamos que dos archivos presentan la siguiente diferencia "
"de una sola línea:"

#. type: Content of: <article><section><section><orderedlist><listitem><formalpara><title>
#: English/Filters.xml:1764 English/Filters.xml:1786 English/Intro_diffs.xml:60
msgid "File1:"
msgstr "Fichero1:"

#. type: Content of: <article><section><section><itemizedlist><listitem><formalpara><para><screen>
#: English/Filters.xml:1766
#, no-wrap
msgid "# Jean Sibelius"
msgstr "# Jean Sibelius"

#. type: Content of: <article><section><section><orderedlist><listitem><formalpara><title>
#: English/Filters.xml:1770 English/Filters.xml:1793 English/Intro_diffs.xml:69
msgid "File2:"
msgstr "Fichero2:"

#. type: Content of: <article><section><section><itemizedlist><listitem><formalpara><para><screen>
#: English/Filters.xml:1772
#, no-wrap
msgid "# Janne Sibelius"
msgstr "# Janne Sibelius"

#. type: Content of: <article><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1775
msgid ""
"With no filtering, the line is detected as a difference. But if we apply a "
"line filter rule with the expression, <code>^#</code>, the lines are "
"reported as identical, because the expression specifies only the first "
"character, which matches in both files."
msgstr ""
"Sin filtrado, la línea se detecta como una diferencia. Pero si aplicamos una "
"regla de filtrado de líneas con la expresión <code>^#</code>, las líneas se "
"consideran idénticas, ya que la expresión solo especifica el primer "
"carácter, que coincide en ambos archivos."

#. type: Content of: <article><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1782
msgid ""
"A rule is applied to a multi-line difference only if all the lines match. "
"For example, consider this two-line difference:"
msgstr ""
"Una regla solo se aplica a una diferencia de varias líneas si todas las "
"líneas coinciden. Por ejemplo, consideremos esta diferencia de dos líneas:"

#. type: Content of: <article><section><section><itemizedlist><listitem><formalpara><para><screen>
#: English/Filters.xml:1788
#, no-wrap
msgid ""
"# Jean Sibelius\n"
"# Pekka Himanen"
msgstr ""
"# Jean Sibelius\n"
"# Pekka Himanen"

#. type: Content of: <article><section><section><itemizedlist><listitem><formalpara><para><screen>
#: English/Filters.xml:1795
#, no-wrap
msgid ""
"# Janne Sibelius\n"
"Pekka Himanen"
msgstr ""
"# Janne Sibelius\n"
"Pekka Himanen"

#. type: Content of: <article><section><section><itemizedlist><listitem><para>
#: English/Filters.xml:1799
msgid ""
"The same <code>^#</code> rule matches the first line, but not the second "
"line. Therefore, the difference is not ignored."
msgstr ""
"La misma regla <code>^#</code> coincide con la primera línea, pero no con la "
"segunda. Por lo tanto, la diferencia no se ignora."

#. type: Content of: <article><section><section><tip><para>
#: English/Filters.xml:1805
msgid ""
"It's usually good practice to use the beginning of line ( <code>^</code> ) "
"and end of line ( <code>$</code> ) markers to control your patterns "
"precisely, because the rule is applied if any part of a line matches the "
"expression."
msgstr ""
"Por lo general, es recomendable utilizar los marcadores de inicio de línea "
"(<code>^</code>) y de fin de línea (<code>$</code>) para controlar los "
"patrones con precisión, ya que la regla se aplica si cualquier parte de una "
"línea coincide con la expresión."

#. type: Content of: <article><section><section><example><title>
#: English/Filters.xml:1812
msgid "Sample line filters"
msgstr "Ejemplos de filtros de línea"

#. type: Content of: <article><section><section><example><screen>
#: English/Filters.xml:1814
#, no-wrap
msgid "^MYTAG$"
msgstr "^MYTAG$"

#. type: Content of: <article><section><section><example><para>
#: English/Filters.xml:1816
msgid "Filters lines that exactly match <literal>MYTAG</literal>"
msgstr "Filtra las líneas que coinciden exactamente <literal>MYTAG</literal>"

#. type: Content of: <article><section><section><example><screen>
#: English/Filters.xml:1818
#, no-wrap
msgid "^::"
msgstr "^::"

#. type: Content of: <article><section><section><example><para>
#: English/Filters.xml:1820
msgid "Filters lines beginning with <literal>::</literal>"
msgstr "Filtra las líneas que comienzan por <literal>::</literal>"

#. type: Content of: <article><section><section><example><screen>
#: English/Filters.xml:1822
#, no-wrap
msgid "^/\\*.*\\*/$"
msgstr "^/\\*.*\\*/$"

#. type: Content of: <article><section><section><example><para>
#: English/Filters.xml:1824
msgid ""
"Filters lines beginning with <literal><constant>/*</constant></literal> and "
"ending with <literal>*/</literal>"
msgstr ""
"Filtra las líneas que empiezan por <literal><constant>/*</constant></"
"literal> y terminan por <literal>*/</literal>"

#. type: Content of: <article><section><section><example><screen>
#: English/Filters.xml:1828
#, no-wrap
msgid "^[1-5]00"
msgstr "^[1-5]00"

#. type: Content of: <article><section><section><example><para>
#: English/Filters.xml:1830
msgid "Filters lines beginning with numbers 100, 200, 300, 400, and 500"
msgstr "Filtra las líneas que empiezan por números 100, 200, 300, 400 y 500"

#. type: Content of: <article><section><section><example><title>
#: English/Filters.xml:1835
msgid "Line filter rule matching CVS Id lines"
msgstr "Regla de filtrado de líneas que coincidan con las líneas de CVS Id"

#. type: Content of: <article><section><section><example><para>
#: English/Filters.xml:1837
msgid "CVS Id lines look like this:"
msgstr "Las líneas de CVS Id tienen este aspecto:"

#. type: Content of: <article><section><section><example><screen>
#: English/Filters.xml:1839
#, no-wrap
msgid "// $Id: Filters.xml 7591 2013-01-20 15:47:42Z christianlist $"
msgstr "// $Id: Filters.xml 7591 2013-01-20 15:47:42Z christianlist $"

#. type: Content of: <article><section><section><example><para>
#: English/Filters.xml:1841 English/Filters.xml:1853
msgid "... and can be filtered with this rule:"
msgstr "... y se pueden filtrar con esta regla:"

#. type: Content of: <article><section><section><example><screen>
#: English/Filters.xml:1843
#, no-wrap
msgid "^// \\WId: .*\\$"
msgstr "^// \\WId: .*\\$"

#. type: Content of: <article><section><section><example><title>
#: English/Filters.xml:1847
msgid "Filter line number comments in po files"
msgstr "Filtrar los comentarios de los números de línea en los archivos po"

#. type: Content of: <article><section><section><example><para>
#: English/Filters.xml:1849
msgid "po line number comments look like this:"
msgstr "Los comentarios de los números de línea de po tienen este aspecto:"

#. type: Content of: <article><section><section><example><screen>
#: English/Filters.xml:1851
#, no-wrap
msgid "#: src/filename.c:766"
msgstr "#: src/filename.c:766"

#. type: Content of: <article><section><section><example><screen>
#: English/Filters.xml:1855
#, no-wrap
msgid "^#"
msgstr "^#"

#. type: Content of: <article><section><title><indexterm><secondary>
#: English/Filters.xml:1864
msgid "substitution"
msgstr "sustitución"

#. type: Content of: <article><section><title>
#: English/Filters.xml:1861
msgid ""
"Using substitution filters<placeholder type=\"indexterm\" id=\"0\"/"
"><placeholder type=\"indexterm\" id=\"1\"/>"
msgstr ""
"Uso de filtros de sustitución<placeholder type=\"indexterm\" id=\"0\"/"
"><placeholder type=\"indexterm\" id=\"1\"/>"

#. type: Content of: <article><section><title><indexterm><primary>
#: English/Filters.xml:1876
msgid "Filters dialog"
msgstr "Diálogo Filtros"

#. type: Content of: <article><section><title><indexterm><secondary>
#: English/Filters.xml:1880
msgid "managing and enabling"
msgstr "gestionar y habilitar"

#. type: Content of: <article><section><title>
#: English/Filters.xml:1875
msgid ""
"Using the Filters dialog<placeholder type=\"indexterm\" id=\"0\"/"
"><placeholder type=\"indexterm\" id=\"1\"/>"
msgstr ""
"Uso del cuadro de diálogo \"Filtros\"<placeholder type=\"indexterm\" "
"id=\"0\"/><placeholder type=\"indexterm\" id=\"1\"/>"

#. type: Content of: <article><section><para>
#: English/Filters.xml:1883
msgid ""
"This section describes the Filters dialog, which provides functions to "
"create and manage file filters and line filters."
msgstr ""
"En esta sección se describe el cuadro de diálogo \"Filtros\", que ofrece "
"funciones para crear y gestionar filtros de archivos y filtros de líneas."

#. type: Content of: <article><section><para>
#: English/Filters.xml:1886
msgid "To open the Filters dialog, use either of these methods:"
msgstr ""
"Para abrir el cuadro de diálogo «Filtros», use cualesquiera de estos métodos:"

#. type: Content of: <article><section><itemizedlist><listitem><para>
#: English/Filters.xml:1890
msgid ""
"In the Select Files or Folders dialog, click <guibutton>Select</guibutton> "
"to the right of the <guilabel>Filter</guilabel> field. You use this method "
"when you want to apply a file filter to a folder compare operation."
msgstr ""
"En el cuadro de diálogo \"Seleccione archivos o carpetas\", haga clic en "
"<guibutton>Seleccionar</guibutton> a la derecha del campo <guilabel>Filtro</"
"guilabel>.  Este método se utiliza cuando se desea aplicar un filtro de "
"archivos a una operación de comparación de carpetas."

#. type: Content of: <article><section><itemizedlist><listitem><para>
#: English/Filters.xml:1897
msgid ""
"Click <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Filters</"
"guimenuitem> </menuchoice>. This method can be used at any time except when "
"the Select Files or Folders dialog is open."
msgstr ""
"Haga clic en<menuchoice> <guimenu>Herramientas</guimenu> "
"<guimenuitem>Filtros</guimenuitem> </menuchoice>. Este método se puede "
"utilizar en cualquier momento, excepto cuando está abierto el cuadro de "
"diálogo \"Seleccione archivos o carpetas\"."

#. type: Content of: <article><section><para>
#: English/Filters.xml:1906
msgid "The Filters dialog has a tab for each type of WinMerge filter:"
msgstr ""
"El cuadro de diálogo \"Filtros\" tiene una pestaña para cada tipo de filtro "
"de WinMerge:"

#. type: Content of: <article><section><variablelist><varlistentry><term>
#: English/Filters.xml:1910
msgid "File Filters"
msgstr "Filtros de archivos"

#. type: Content of: <article><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1913
msgid ""
"Choose this tab to work with file filters for folder compare operations."
msgstr ""
"Seleccione esta pestaña para utilizar filtros de archivos en las operaciones "
"de comparación de carpetas."

#. type: Content of: <article><section><variablelist><varlistentry><term>
#: English/Filters.xml:1919
msgid "Line Filters"
msgstr "Filtros de líneas"

#. type: Content of: <article><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1922
msgid "Choose this tab to work with line filters for file compare operations."
msgstr ""
"Seleccione esta pestaña para utilizar filtros de líneas en las operaciones "
"de comparación de archivos."

#. type: Content of: <article><section><variablelist><varlistentry><term>
#: English/Filters.xml:1928
msgid "Substitution Filters"
msgstr "Filtros de sustitución"

#. type: Content of: <article><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1931
msgid ""
"Choose this tab to work with substitution filters for file compare "
"operations."
msgstr ""
"Seleccione esta pestaña para trabajar con filtros de sustitución en las "
"operaciones de comparación de archivos."

#. type: Content of: <article><section><section><title><indexterm><secondary>
#: English/Filters.xml:1941 English/Filters.xml:2207 English/Filters.xml:2299
msgid "enabling"
msgstr "habilitar"

#. type: Content of: <article><section><section><title>
#: English/Filters.xml:1938
msgid "Using the File Filters tab<placeholder type=\"indexterm\" id=\"0\"/>"
msgstr ""
"Uso de la pestaña \"Filtros de archivos\"<placeholder type=\"indexterm\" "
"id=\"0\"/>"

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:1944
msgid ""
"The main part of this tab is a list of file filters that are available for "
"folder compare operations. The list includes shared, private, and installed "
"file filters that WinMerge knows about, as described in <xref "
"linkend=\"Filters_FileFilterLoc\" />."
msgstr ""
"La parte principal de esta pestaña es una lista de filtros de archivos "
"disponibles para las operaciones de comparación de carpetas. La lista "
"incluye filtros de archivos compartidos, privados e instalados que WinMerge "
"reconoce, tal y como se describe en <xref linkend=\"Filters_FileFilterLoc\" /"
">."

#. type: Content of: <article><section><section><section><title>
#: English/Filters.xml:1950
msgid "Enabling and disabling file filters"
msgstr "Activar y desactivar los filtros de archivos"

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:1952
msgid ""
"You must enable a file filter to make it available in a folder comparison "
"operation, or to disable a current filter to stop it from being used:"
msgstr ""
"Debe habilitar un filtro de archivos para que esté disponible en una "
"operación de comparación de carpetas o deshabilitar un filtro actual para "
"que deje de utilizarse:"

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:1958
msgid "Open the Filters dialog, if it is not already open."
msgstr "Abra el cuadro de diálogo \"Filtros\", si aún no está abierto."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:1962
msgid ""
"Select a file filter or <guimenuitem>&lt;None&gt;</guimenuitem> from the "
"list."
msgstr ""
"Selecciona un filtro de archivos o <guimenuitem>&lt;Ninguno&gt;</"
"guimenuitem> de la lista."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:1967
msgid "Click <guibutton>OK</guibutton> to dismiss the Filters dialog."
msgstr ""
"Haga clic en <guibutton>Aceptar</guibutton> para cerrar el cuadro de diálogo "
"\"Filtros\"."

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:1972
msgid ""
"There are several ways to apply file filters after enabling them.  For "
"details, see <xref linkend=\"Filters_FileFilterApply\" />."
msgstr ""
"Hay varias formas de aplicar filtros de archivos una vez habilitados. Para "
"obtener más información, consulte <xref linkend=\"Filters_FileFilterApply\" /"
">."

#. type: Content of: <article><section><section><section><title>
#: English/Filters.xml:1977
msgid "Configuring file filters"
msgstr "Configuración de filtros de archivos"

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:1979
msgid ""
"Use these buttons to manage your <guilabel>File Filters</guilabel> list and "
"create new file filters:"
msgstr ""
"Utilice estos botones para gestionar su lista de <guilabel>filtros de "
"archivos</guilabel> y crear nuevos filtros:"

#. type: Content of: <article><section><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:1984
msgid "Test"
msgstr "Probar..."

#. type: Content of: <article><section><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1987
msgid ""
"Select a file filter in the list and click <guibutton>Test</guibutton> to "
"quickly see how the filter works.  See <xref linkend=\"Filters_TestingDlg\" /"
"> for details."
msgstr ""
"Seleccione un filtro de archivos de la lista y haga clic en "
"<guibutton>Probar...</guibutton> para ver rápidamente cómo funciona el "
"filtro. Consulte <xref linkend=\"Filters_TestingDlg\" /> para obtener más "
"información."

#. type: Content of: <article><section><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:1994
msgid "Install"
msgstr "Instalar..."

#. type: Content of: <article><section><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:1997
msgid ""
"Enables you to locate a file filter and adds it to the Filters list. File "
"filters that are not in either the shared or default private folder are not "
"detected unless you install them."
msgstr ""
"Le permite buscar un filtro de archivos y añadirlo a la lista de filtros. "
"Los filtros de archivos que no se encuentren ni en la carpeta compartida ni "
"en la carpeta privada predeterminada no se detectarán a menos que los "
"instale."

#. type: Content of: <article><section><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:2005
msgid "New"
msgstr "Nuevo..."

#. type: Content of: <article><section><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:2008
msgid ""
"Creates a new copy of a file template in either the shared or private filter "
"folders, and opens it in your default editor.  Edit the template and add "
"your rules, as described in <xref linkend=\"Filters_CreatingFile\" />."
msgstr ""
"Crea una nueva copia de una plantilla de archivo en las carpetas de filtros "
"compartidas o privadas y la abre en su editor predeterminado.  Edite la "
"plantilla y añada sus reglas, tal y como se describe en <xref "
"linkend=\"Filters_CreatingFile\" />."

#. type: Content of: <article><section><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:2016
msgid "Edit"
msgstr "Editar..."

#. type: Content of: <article><section><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:2019
msgid ""
"Select a file filter in the list and click <guibutton>Edit</guibutton> to "
"open the file in your default editor."
msgstr ""
"Seleccione un filtro de archivos de la lista y haga clic en "
"<guibutton>Editar...</guibutton> para abrir el archivo en su editor "
"predeterminado.  editor."

#. type: Content of: <article><section><section><section><variablelist><varlistentry><term>
#: English/Filters.xml:2026
msgid "Delete"
msgstr "Eliminar..."

#. type: Content of: <article><section><section><section><variablelist><varlistentry><listitem><para>
#: English/Filters.xml:2029
msgid ""
"Select a file filter in the list and click <guibutton>Delete</guibutton> to "
"delete the file and remove it from the list. Yes, the file is really deleted!"
msgstr ""
"Seleccione un filtro de archivos de la lista y haga clic en "
"<guibutton>Eliminar...</guibutton> para borrar el archivo y eliminarlo de la "
"lista. ¡Sí, el archivo es borrado de verdad!"

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:2036
msgid ""
"Your changes are saved when you click <guibutton>OK</guibutton> to dismiss "
"the Filters dialog. Line filters are stored in the Windows registry."
msgstr ""
"Los cambios se guardan al hacer clic en <guibutton>Aceptar</guibutton> para "
"cerrar el cuadro de diálogo «Filtros». Los filtros de línea se guardan en el "
"Registro de Windows."

#. type: Content of: <article><section><section><section><title>
#: English/Filters.xml:2042
msgid "Creating a file filter"
msgstr "Creación de un filtro de archivos"

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:2044
msgid ""
"If the file filters that are installed with WinMerge do not provide the "
"filtering you need, you can create your own:"
msgstr ""
"Si los filtros de archivos que se instalan con WinMerge no le proporcionan "
"el filtrado que necesita, puede crear los suyos propios:"

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2049
msgid ""
"Click <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Filters</"
"guimenuitem> </menuchoice>. Or, from the Select Files or Folders dialog, "
"click <guibutton>Select</guibutton> to the right of the <guilabel>Filter</"
"guilabel> field."
msgstr ""
"Haga clic en<menuchoice> <guimenu>Herramientas</guimenu> "
"<guimenuitem>Filtros</guimenuitem> </menuchoice>. O bien, en el cuadro de "
"diálogo \"Seleccione archivos o carpetas\", haga clic en "
"<guibutton>Seleccionar</guibutton> a la derecha del campo <guilabel>Filtro</"
"guilabel>."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2059
msgid ""
"In the Filters dialog File Filters tab, click <guibutton>New</guibutton>."
msgstr ""
"En la pestaña \"Filtros de archivos\" del cuadro de diálogo \"Filtros\", "
"haga clic en <guibutton>Nuevo</guibutton>."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2064
msgid ""
"In the Shared or Private Filter dialog, choose <guilabel>Shared Filter</"
"guilabel> or <guilabel>Private Filter</guilabel> (see <xref "
"linkend=\"Filters_FileFilterLoc\" /> for their uses) and click <keycap>OK</"
"keycap>."
msgstr ""
"En el cuadro de diálogo \"Filtro compartido o privado\" seleccione "
"<guilabel>Filtro compartido</guilabel> o <guilabel>Filtro privado </"
"guilabel> (consulte <xref linkend=\"Filters_FileFilterLoc\" /> para conocer "
"sus usos)  y haga clic en <keycap>Aceptar</keycap>."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2069
msgid ""
"The Select Filename for New Filter dialog opens in the shared or private "
"files folder on your system (if the private folder does not exist, WinMerge "
"creates it)."
msgstr ""
"Se abre el cuadro de diálogo \"Seleccione un nombre de archivo para el nuevo "
"filtro\" en la carpeta de archivos compartidos o privados de su sistema (si "
"la carpeta privada no existe, WinMerge la creará)."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2075
msgid ""
"In the Select Filename for New Filter dialog, enter a new file name and "
"click <guibutton>Save</guibutton>."
msgstr ""
"En el cuadro de diálogo \"Seleccione un nombre de archivo para el nuevo "
"filtro\", introduzca un nuevo nombre de archivo y haga clic en "
"<guibutton>Guardar</guibutton>."

#. type: Content of: <article><section><section><section><orderedlist><listitem><note><para>
#: English/Filters.xml:2079
msgid ""
"Don't choose an existing file name: to edit an existing file, go back to "
"Step <xref linkend=\"Filters_New_step\" /> and click Edit instead of New."
msgstr ""
"No elija un nombre de archivo que ya exista: para editar un archivo "
"existente, vuelva al paso <xref linkend=\"Filters_New_step\" /> y haga clic "
"en \"Editar...\" en lugar de \"Nuevo...\"."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2084
msgid ""
"WinMerge initializes the new file with the contents of the "
"<filename>FileFilter.tmpl</filename> template, and opens it in your default "
"text editor."
msgstr ""
"WinMerge inicializa el nuevo archivo con el contenido de la plantilla "
"<filename>FileFilter.tmpl</filename> y lo abre en su editor de texto "
"predeterminado"

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2090
msgid ""
"Follow the template instructions to edit the template, updating the "
"placeholder name and description and adding filter rules as described in "
"<xref linkend=\"Filters_FileFilterSyntax\" />.  Save the file in your text "
"editor."
msgstr ""
"Siga las instrucciones de la plantilla para editarla, actualizando el nombre "
"y la descripción del marcador de posición y añadiendo reglas de filtrado, "
"tal y como se describe en la sección <xref "
"linkend=\"Filters_FileFilterSyntax\" />.  Guarde el archivo en su editor de "
"texto."

#. type: Content of: <article><section><section><section><orderedlist><listitem><tip><para>
#: English/Filters.xml:2096
msgid ""
"If you want to quickly test a rule that you are defining, try clicking Test "
"in the Filters dialog. See <xref linkend=\"Filters_TestingDlg\" /> for "
"details."
msgstr ""
"Si quiere probar rápidamente una regla que está definiendo, haga clic en "
"\"Probar...\" en el cuadro de diálogo \"Filtros\". Consulte <xref "
"linkend=\"Filters_TestingDlg\" /> para obtener más información."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2104
msgid ""
"If you created your file filter in one of the standard <filename>Filters</"
"filename> folders, and the Filters dialog does not list your new file "
"filter, try clicking <guibutton>OK</guibutton> to close it, then click "
"<menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Filters</guimenuitem> </"
"menuchoice> again to reopen it. The <guilabel>File Filters</guilabel> list "
"should now include the new file filter."
msgstr ""
"Si ha creado el filtro de archivos en una de las carpetas de filtros "
"predeterminadas y el cuadro de diálogo <filename>Filtros</filename> no "
"muestra el nuevo filtro, intente hacer clic en <guibutton>Aceptar</"
"guibutton> para cerrarlo y, a continuación, vuelva a hacer clic en "
"<menuchoice> <guimenu>Herramientas</guimenu> <guimenuitem>Filtros</"
"guimenuitem> </menuchoice> para volver a abrirlo. La lista de "
"<guilabel>Filtros de archivos</guilabel> debería incluir ahora el nuevo "
"filtro."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2115
msgid ""
"If you saved the file in an alternate location on your file system), "
"WinMerge cannot detect it unless you install it. To make a file filter "
"detectable anywhere on your system:"
msgstr ""
"Si ha guardado el archivo en una ubicación diferente de su sistema de "
"archivos, WinMerge no podrá detectarlo a menos que lo instale. Para que un "
"filtro de archivos sea detectable en cualquier lugar del sistema:"

#. type: Content of: <article><section><section><section><orderedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:2121
msgid "Click <guibutton>Install</guibutton> in the Filters dialog."
msgstr ""
"Haga clic en <guibutton>Instalar...</guibutton> en el cuadro de diálogo "
"Filtros."

#. type: Content of: <article><section><section><section><orderedlist><listitem><orderedlist><listitem><para>
#: English/Filters.xml:2126
msgid ""
"In the Locate Filter File to Install dialog, navigate to the <filename>flt</"
"filename> file on your system, and click <guibutton>Open</guibutton>. The "
"File Filters list should now include the installed file filter."
msgstr ""
"En el cuadro de diálogo \"Buscar archivo de filtro para instalar\", busque "
"el archivo <filename>flt</filename> en su sistema y haga clic en "
"<guibutton>Abrir</guibutton>. La lista \"Filtros de archivos\" debería "
"incluir ahora el filtro de archivo instalado."

#. type: Content of: <article><section><section><section><title><indexterm><secondary>
#: English/Filters.xml:2140
msgid "testing"
msgstr "probando"

#. type: Content of: <article><section><section><section><title><indexterm><primary>
#: English/Filters.xml:2142
msgid "testing file filters"
msgstr "prueba de filtros de archivos"

#. type: Content of: <article><section><section><section><title>
#: English/Filters.xml:2137
msgid ""
"Testing file filter rules<placeholder type=\"indexterm\" id=\"0\"/"
"><placeholder type=\"indexterm\" id=\"1\"/>"
msgstr ""
"Comprobación de las reglas de filtrado de archivos<placeholder "
"type=\"indexterm\" id=\"0\"/><placeholder type=\"indexterm\" id=\"1\"/>"

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:2145
msgid ""
"Use the Test Filter dialog to quickly test a file filter against sample "
"data, to help you develop new rules or to understand how existing rules "
"work. It can be easier than running a full compare operation."
msgstr ""
"Utilice el cuadro de diálogo \"Probar filtro\" para comprobar rápidamente un "
"filtro de archivos con datos de ejemplo, lo que le ayudará a desarrollar "
"nuevas reglas o a comprender cómo funcionan las reglas existentes. Puede "
"resultar más sencillo que ejecutar una operación de comparación completa."

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:2150
msgid "Starting from the Filters dialog:"
msgstr "Empezando desde el cuadro de diálogo \"Filtros\":"

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2154
msgid "In the File Filters tab, choose the file filter you want to test."
msgstr ""
"En la pestaña \"Filtros de archivos\" seleccione el filtro de archivos que "
"desee probar."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2159
msgid ""
"If you want to see the rules you will be testing, click <guibutton>Edit</"
"guibutton> now to open the file so that you can view it during the next "
"steps."
msgstr ""
"Si quiere ver las reglas que va a probar, haga clic en <guibutton>Editar...</"
"guibutton> para abrir el archivo y poder consultarlo durante los siguientes "
"pasos."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2165
msgid "Click <guibutton>Test</guibutton>."
msgstr "Haga clic en<guibutton>Probar...</guibutton>."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2169
msgid "In the Test Filter dialog, choose the type of rule to test:"
msgstr ""
"En el cuadro de diálogo \"Probar filtro\" seleccione el tipo de regla que "
"desea probar:"

#. type: Content of: <article><section><section><section><orderedlist><listitem><itemizedlist><listitem><para>
#: English/Filters.xml:2174
msgid ""
"To test an <guilabel>f:</guilabel> file rule in your file filter, uncheck "
"the <guilabel>Folder Name</guilabel> option."
msgstr ""
"Para probar una regla de archivos <guilabel>f:</guilabel> en su filtro de "
"archivos, desmarque la opción <guilabel>Nombre de carpeta</guilabel>."

#. type: Content of: <article><section><section><section><orderedlist><listitem><itemizedlist><listitem><para>
#: English/Filters.xml:2180
msgid ""
"To test a <guilabel>d:</guilabel> folder rule, check the <guilabel>Folder "
"Name</guilabel> option."
msgstr ""
"Para probar una regla de la carpeta <guilabel>d:</guilabel> marque la opción "
"<guilabel>Nombre de carpeta</guilabel>."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2187
msgid "Enter the text to test."
msgstr "Texto para probar."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2189
msgid ""
"The text should be appropriate for the type of rule you are testing. For "
"example, if you have checked the <guilabel>Folder Name</guilabel> option, "
"you probably want to enter a folder name, such as \\temp."
msgstr ""
"El texto debe ser adecuado para el tipo de regla que esté probando. Por "
"ejemplo, si ha marcado la opción <guilabel>Nombre de carpeta</guilabel>, "
"probablemente querrá introducir un nombre de carpeta, como \\temp."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2194
msgid ""
"The <guilabel>Result</guilabel> box displays your entry, followed by its "
"status: either <computeroutput>passed</computeroutput> or "
"<computeroutput>failed</computeroutput>."
msgstr ""
"En el cuadro <guilabel>Resultado</guilabel> aparece su entrada, seguida de "
"su estado: <computeroutput>passed</computeroutput> o <computeroutput>failed</"
"computeroutput>."

#. type: Content of: <article><section><section><title>
#: English/Filters.xml:2204
msgid "Using the Line Filters tab<placeholder type=\"indexterm\" id=\"0\"/>"
msgstr ""
"Uso de la pestaña \"Filtros de líneas\"<placeholder type=\"indexterm\" "
"id=\"0\"/>"

#. type: Content of: <article><section><section><para>
#: English/Filters.xml:2210
msgid ""
"Use this tab to configure and enable line filters for file compare "
"operations. The tab features a list of rules. Each rule contains a single "
"regular expression. You can apply any combination of rules from the list to "
"a file comparison."
msgstr ""
"Utilice esta pestaña para configurar y activar filtros de líneas en las "
"operaciones de comparación de archivos. La pestaña incluye una lista de "
"reglas. Cada regla contiene una única expresión regular. Puede aplicar "
"cualquier combinación de reglas de la lista a una comparación de archivos."

#. type: Content of: <article><section><section><section><title>
#: English/Filters.xml:2216
msgid "Configuring line filters"
msgstr "Configuración de filtros de líneas"

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:2218
msgid ""
"Below the <guilabel>Regular Expressions</guilabel> list is an edit box and "
"buttons that you can use to maintain the list at any time by adding, "
"editing, and removing rules."
msgstr ""
"Debajo de la lista <guilabel>Expresiones regulares</guilabel> hay un cuadro "
"de edición y unos botones que puede utilizar para mantener la lista "
"actualizada en cualquier momento añadiendo, editando y eliminando reglas."

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:2222
msgid "To add a new rule:"
msgstr "Para añadir una nueva regla:"

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2226
msgid ""
"Click <guibutton>New</guibutton>. Your edit cursor is automatically enabled "
"in the edit box."
msgstr ""
"Haga clic en <guibutton>Nuevo</guibutton>. El cursor de edición se activa "
"automáticamente en el cuadro de edición."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2231
msgid ""
"Enter an expression in the edit box below the <guilabel>Regular Expressions</"
"guilabel> list."
msgstr ""
"Introduzca una expresión en el cuadro de edición situado debajo de la lista "
"<guilabel>Expresiones regulares</guilabel>."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2236
msgid ""
"Click <guibutton>Save</guibutton> to load the expression in a new line in "
"the list."
msgstr ""
"Haga clic en <guibutton>Guardar</guibutton> para cargar la expresión en una "
"nueva línea de la lista."

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:2241
msgid "To edit an existing rule:"
msgstr "Para editar una regla existente:"

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2245
msgid "Select the line and click <guibutton>Edit</guibutton>."
msgstr "Seleccione la línea y haga clic en <guibutton>Editar</guibutton>."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2249
msgid "Edit the expression in the edit box."
msgstr "Edite la expresión en el cuadro de edición."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2253
msgid ""
"Click <guibutton>Save</guibutton><guibutton> </guibutton>when you're done."
msgstr "Haga clic en <guibutton>Guardar</guibutton> cuando haya terminado."

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:2258
msgid ""
"To delete an existing rule, select (check) the rule and click "
"<guibutton>Remove</guibutton>."
msgstr ""
"Para eliminar una regla existente, selecciónela (marque la casilla)  y haga "
"clic en <guibutton>Eliminar</guibutton>."

#. type: Content of: <article><section><section><section><title><indexterm><secondary>
#: English/Filters.xml:2266 English/Filters.xml:2315
msgid "list of available"
msgstr "lista de disponibles"

#. type: Content of: <article><section><section><section><title>
#: English/Filters.xml:2263
msgid ""
"Enabling and disabling line filters<placeholder type=\"indexterm\" id=\"0\"/>"
msgstr ""
"Activación y desactivación de los filtros de líneas<placeholder "
"type=\"indexterm\" id=\"0\"/>"

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2271
msgid ""
"In the <guilabel>Regular Expressions</guilabel> list, check just the filters "
"that you want to apply, and uncheck any filters you do not want to apply."
msgstr ""
"En la lista de <guilabel>Expresiones regulares</guilabel> marque solo los "
"filtros que desee aplicar y desmarque los que no desee aplicar."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2277
msgid ""
"Check or uncheck the <guilabel>Enable Line Filters</guilabel> option. If you "
"turn filtering on, all the rules that are currently checked in the "
"<guilabel>Regular Expression</guilabel> list are used. If filtering is off, "
"no rules are used even if they are checked."
msgstr ""
"Marque o desmarque la opción <guilabel>Habilitar Filtros de líneas</"
"guilabel>. Si activa el filtrado, se utilizarán todas las reglas que estén "
"marcadas actualmente en la lista <guilabel>Expresión regular</guilabel>. Si "
"el filtrado está desactivado, no se utilizará ninguna regla, aunque estén "
"marcadas."

#. type: Content of: <article><section><section><section><orderedlist><listitem><para>
#: English/Filters.xml:2285
msgid ""
"Click <guibutton>OK</guibutton> to dismiss the Filters dialog and save your "
"settings."
msgstr ""
"Haga clic en <guibutton>Aceptar</guibutton> para cerrar el cuadro de diálogo "
"\"Filtros\" y guardar la configuración."

#. type: Content of: <article><section><section><section><para>
#: English/Filters.xml:2290
msgid ""
"There are several ways to apply file filters after enabling them.  For "
"details, see <xref linkend=\"Filters_LineFilterApply\" />."
msgstr ""
"Hay varias formas de aplicar filtros de archivos una vez activados.  Para "
"más información, consulte <xref linkend=\"Filters_LineFilterApply\" />."

#. type: Content of: <article><section><section><title>
#: English/Filters.xml:2296
msgid ""
"Using the Substitution Filters tab<placeholder type=\"indexterm\" id=\"0\"/>"
msgstr ""
"Uso de la pestaña \"Filtros de sustitución\"<placeholder type=\"indexterm\" "
"id=\"0\"/>"

#. type: Content of: <article><section><section><section><title>
#: English/Filters.xml:2305
msgid "Configuring substitution filters"
msgstr "Configuración de Filtros de sustitución"

#. type: Content of: <article><section><section><section><title>
#: English/Filters.xml:2312
msgid ""
"Enabling and disabling substitution filters<placeholder type=\"indexterm\" "
"id=\"0\"/>"
msgstr ""
"Activación y desactivación de los filtros de sustitución<placeholder "
"type=\"indexterm\" id=\"0\"/>"

#. type: Content of: <article><section><title><indexterm><secondary>
#: English/Filters.xml:2327
msgid "getting help"
msgstr "obtener ayuda"

#. type: Content of: <article><section><title>
#: English/Filters.xml:2324
msgid ""
"Getting help with regular expressions<placeholder type=\"indexterm\" "
"id=\"0\"/>"
msgstr ""
"Obtener ayuda sobre expresiones regulares<placeholder type=\"indexterm\" "
"id=\"0\"/>"

#. type: Content of: <article><section><para>
#: English/Filters.xml:2330
msgid ""
"Regular expressions can be very complex. Fortunately, most file filters in "
"WinMerge involve simple extension expressions, as shown in the examples in "
"this topic. The filter files installed with WinMerge include many other "
"useful examples."
msgstr ""
"Las expresiones regulares pueden ser muy complejas. Afortunadamente, la "
"mayoría de los filtros de archivos de WinMerge utilizan expresiones de "
"extensión sencillas, tal y como se muestra en los ejemplos de este tema. Los "
"archivos de filtro que se instalan con WinMerge incluyen muchos otros "
"ejemplos útiles."

#. type: Content of: <article><section><para>
#: English/Filters.xml:2335
msgid ""
"Finally, there are lots of resources on the Web for help with regexps, "
"including these sites:"
msgstr ""
"Por último, hay muchos recursos en Internet que pueden servir de ayuda con "
"las expresiones regulares, entre ellos estos sitios web:"

#. type: Content of: <article><section><variablelist><varlistentry><term>
#: English/Filters.xml:2340
msgid "Good site devoted to regexps:"
msgstr "Una buena página web dedicada a las expresiones regulares:"

#. type: Content of: <article><section><variablelist><varlistentry><listitem><simpara>
#: English/Filters.xml:2343
msgid ""
"<ulink url=\"https://www.regular-expressions.info/\">https://www.regular-"
"expressions.info/</ulink>"
msgstr ""
"<ulink url=\"https://www.regular-expressions.info/\">https://www.regular-"
"expressions.info/</ulink>"

#. type: Content of: <article><section><variablelist><varlistentry><term>
#: English/Filters.xml:2349
msgid "Tutorial:"
msgstr "Tutorial:"

#. type: Content of: <article><section><variablelist><varlistentry><listitem><simpara>
#: English/Filters.xml:2352
msgid ""
"<ulink url=\"http://www.zvon.org/comp/r/tut-Regexp.html\">http://www.zvon."
"org/comp/r/tut-Regexp.html</ulink>"
msgstr ""
"<ulink url=\"http://www.zvon.org/comp/r/tut-Regexp.html\">http://www.zvon."
"org/comp/r/tut-Regexp.html</ulink>"

#. type: Content of: <article><section><variablelist><varlistentry><term>
#: English/Filters.xml:2358
msgid "PDF quick reference:"
msgstr "Guía rápida en PDF:"

#. type: Content of: <article><section><variablelist><varlistentry><listitem><simpara>
#: English/Filters.xml:2361
msgid ""
"<ulink url=\"https://github.com/GordonMcKinney/gist-assets/raw/master/regex."
"pdf\"> https://github.com/GordonMcKinney/gist-assets/raw/master/regex.pdf</"
"ulink>"
msgstr ""
"<ulink url=\"https://github.com/GordonMcKinney/gist-assets/raw/master/regex."
"pdf\"> https://github.com/GordonMcKinney/gist-assets/raw/master/regex.pdf</"
"ulink>"

