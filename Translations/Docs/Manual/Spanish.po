"<filename>editor addin<placeholder type=\"indexterm\" id=\"0\"/></filename>"
msgstr ""
"<filename>editor addin<placeholder type=\"indexterm\" id=\"0\"/></filename>"

#. type: Content of: <article><section><section><para>
#: English/Plugins.xml:2738
msgid ""
"Adds some functions to the <menuchoice> <guimenu>Plugins</guimenu> "
"<guisubmenu>Scripts</guisubmenu> </menuchoice> menu:"
msgstr ""
"Añade algunas funciones al menú<menuchoice> <guimenu>Complementos</guimenu> "
"<guisubmenu>Guiones</guisubmenu> </menuchoice>:"

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2746
msgid ""
"<guimenuitem>Make Uppercase</guimenuitem> convert the selection to UPPER "
"CASE."
msgstr ""
"<guimenuitem>Convertir a mayúsculas</guimenuitem> convierte el texto "
"seleccionado a mayúsculas."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2751
msgid ""
"<guimenuitem>Make Lowercase</guimenuitem> convert the selection to lower "
"case."
msgstr ""
"<guimenuitem>Convertir a minúsculas</guimenuitem> convierte el texto "
"seleccionado a minúsculas."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2756
msgid ""
"<guimenuitem>Remove Duplicate Lines</guimenuitem> remove duplicate lines in "
"the selection."
msgstr ""
"<guimenuitem>Eliminar líneas duplicadas</guimenuitem> elimina las líneas "
"duplicadas de la selección."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2761
msgid ""
"<guimenuitem>Count Duplicate Lines</guimenuitem> remove duplicate lines in "
"the selection and insert the number of duplicate lines on the right."
msgstr ""
"<guimenuitem>Contar líneas duplicadas</guimenuitem> elimina las líneas "
"duplicadas de la selección e inserta el número de líneas duplicadas al "
"derecho."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2766
msgid ""
"<guimenuitem>Sort Lines Ascending</guimenuitem> sort the selection in "
"ascending order."
msgstr ""
"<guimenuitem>Ordenar líneas en orden ascendente</guimenuitem> ordena la "
"selección en orden ascendente."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2771
msgid ""
"<guimenuitem>Sort Lines Descending</guimenuitem> sort the selection in "
"descending order."
msgstr ""
"<guimenuitem>Ordenar líneas en orden descendente</guimenuitem> ordena la "
"selección en orden descendente."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2776
msgid ""
"<guimenuitem>Reverse Columns</guimenuitem> reverse columns in the selection."
msgstr ""
"<guimenuitem>Invertir columnas</guimenuitem> invierte las columnas de la "
"selección."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2781
msgid ""
"<guimenuitem>Reverse Lines</guimenuitem> reverse lines in the selection."
msgstr ""
"<guimenuitem>Invertir líneas</guimenuitem> invierte las líneas de la "
"selección."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2786
msgid ""
"<guimenuitem>Select Columns...</guimenuitem> select some columns in the "
"selection."
msgstr ""
"<guimenuitem>Seleccionar columnas...</guimenuitem> selecciona algunas "
"columnas de la lista."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2791
msgid ""
"<guimenuitem>Select Lines...</guimenuitem> select some lines in the "
"selection."
msgstr ""
"<guimenuitem>Seleccionar líneas...</guimenuitem> selecciona algunas líneas "
"de la selección."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2796
msgid ""
"<guimenuitem>Replace...</guimenuitem> replace text in the selection with "
"another text."
msgstr ""
"<guimenuitem>Sustituir...</guimenuitem> sustituye el texto seleccionado por "
"otro texto."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2801
msgid ""
"<guimenuitem>Apply Filter Command...</guimenuitem> replace the selection "
"with the output of the specified filter command.  Specifying %1 in the "
"argument of the filter command replaces it with the filename of the active "
"pane."
msgstr ""
"<guimenuitem>Aplicar comando de filtro...</guimenuitem> sustituye la "
"selección por el resultado del comando de filtro especificado. Si se "
"especifica %1 en el argumento del comando de filtro, este se sustituye por "
"el nombre del archivo del panel activo."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2807
msgid ""
"<guimenuitem>Tokenize...</guimenuitem> replaces the token delimiter with a "
"newline in the selection."
msgstr ""
"<guimenuitem>Tokenizar...</guimenuitem> sustituye el delimitador de tokens "
"por un salto de línea en la selección."

#. type: Content of: <article><section><section><itemizedlist><listitem><simpara>
#: English/Plugins.xml:2812
msgid ""
"<guimenuitem>Trim Spaces</guimenuitem> remove spaces at the beginning and "
"end of lines in the selection."
msgstr ""
"<guimenuitem>Eliminar espacios</guimenuitem> elimina los espacios al "
"principio y al final de las líneas de la selección."

